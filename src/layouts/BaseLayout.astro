---
export interface Props {
  title: string;
  schema?: string;
  description?: string;
}
const { title, schema, description = 'A comprehensive pharmacology reference for medical and nursing students.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | PharmRef</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href={`${base}styles/global.css`} />
    <link rel="stylesheet" href={`${base}styles/print.css`} media="print" />
  </head>
  <body data-schema={schema} class="min-h-screen bg-base-100 font-sans">
    <slot />
  </body>
</html>
