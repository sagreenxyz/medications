---
interface Props {
  title: string;
}
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Medications information site" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <div class="navbar bg-base-100 shadow-lg">
      <div class="navbar-start">
        <a href={base} class="btn btn-ghost text-xl">💊 Medications</a>
      </div>
      <div class="navbar-center hidden lg:flex">
        <ul class="menu menu-horizontal px-1">
          <li><a href={base}>Home</a></li>
          <li><a href={`${base}about`}>About</a></li>
        </ul>
      </div>
      <div class="navbar-end">
        <label class="swap swap-rotate btn btn-ghost btn-circle">
          <input type="checkbox" class="theme-controller" value="dark" />
          <svg class="swap-off fill-current w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7,5,6.29a1,1,0,0,0-1.41,1.41L4.22,8.3A1,1,0,0,0,5.64,7Zm12,.29.71-.71a1,1,0,1,0-1.41-1.41L16.23,6A1,1,0,0,0,17.66,7.29ZM19,11H18a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Zm6.36,2-.71-.71a1,1,0,0,0-1.41,1.41l.71.71a1,1,0,0,0,1.41-1.41ZM20,12a1,1,0,0,0,1,1h1a1,1,0,0,0,0-2H21A1,1,0,0,0,20,12ZM12,19a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19Z"/></svg>
          <svg class="swap-on fill-current w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"/></svg>
        </label>
      </div>
    </div>
    <main class="container mx-auto px-4 py-8">
      <slot />
    </main>
    <footer class="footer footer-center p-10 bg-base-200 text-base-content rounded mt-8">
      <div>
        <p class="font-bold">💊 Medications</p>
        <p>Your trusted medication information resource</p>
      </div>
      <div>
        <p>Copyright © 2024 - All rights reserved</p>
      </div>
    </footer>
  </body>
</html>
