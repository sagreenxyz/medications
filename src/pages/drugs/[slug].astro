---
import DrugProfileLayout from '../../layouts/DrugProfileLayout.astro';
import Nav from '../../components/Nav.astro';
import drugsData from '../../../data/drugs.json';

export async function getStaticPaths() {
  return (drugsData as any[]).map(drug => ({
    params: { slug: drug.id },
    props: { drug },
  }));
}

const { drug } = Astro.props as { drug: any };
const base = import.meta.env.BASE_URL;
const allDrugs = drugsData as any[];

// Find prototype if this is a variation
const prototypeDrug = drug.prototype_drug
  ? allDrugs.find(d => d.id === drug.prototype_drug || d.generic_name.toLowerCase().replace(/\s+/g, '-') === drug.prototype_drug)
  : null;

// Related drugs — same drug class, limit 5
const relatedDrugs = allDrugs
  .filter(d => d.id !== drug.id && d.drug_class === drug.drug_class)
  .slice(0, 5);

// Schema membership links
const schemaMaps = [
  { key: 'organ_system', label: 'Organ Systems', base: 'schemas/01-organ-systems' },
  { key: 'therapeutic_class', label: 'Therapeutic Classes', base: 'schemas/02-therapeutic-classes' },
  { key: 'mechanism_family', label: 'Mechanism-First', base: 'schemas/04-mechanism-first' },
  { key: 'prototype_class', label: 'Prototype + Class', base: 'schemas/05-prototype-class' },
  { key: 'presentation_cluster', label: 'Clinical Presentations', base: 'schemas/07-clinical-presentations' },
  { key: 'adverse_cluster', label: 'Adverse Effects', base: 'schemas/08-adverse-effects' },
  { key: 'interaction_cluster', label: 'Drug Interactions', base: 'schemas/09-drug-interactions' },
];

// Valid page slugs for each schema — used to filter broken links
const validOrganSystems = new Set(['cardiovascular','renal','respiratory','gastrointestinal','endocrine','reproductive','cns','pns-autonomic','musculoskeletal','hematology-oncology','immunology','infectious-disease','dermatology','ophthalmology-ent','toxicology']);
const validTherapeuticClasses = new Set(['adrenergic','cholinergic','ion-channel','enzyme-inhibitors','receptor-antagonists','transporter-inhibitors','hormones-analogs','biologics','antimicrobials','cytotoxics','anticoagulants']);
const validMechanismTargets = new Set(['gpcr-adrenergic','gpcr-cholinergic','gpcr-opioid','gpcr-histamine','gpcr-angiotensin','gpcr-dopamine','gpcr-serotonin','ligand-gated-channels','voltage-gated-sodium','voltage-gated-calcium','voltage-gated-potassium','nuclear-receptors','receptor-tyrosine-kinases','serine-threonine-kinases','enzyme-ace','enzyme-cox','enzyme-hmgcoa','enzyme-pde','enzyme-thymidylate','transporter-sert-dat-net','transporter-pgp','structural-tubulin','structural-dna']);
const validPresentations = new Set(['hypertension','heart-failure','acute-coronary-syndrome','atrial-fibrillation','dyslipidemia','dvt-pe','shock','asthma','copd','pneumonia','tuberculosis','hiv','hyperglycemia-dka','hypothyroidism','hyperthyroidism','adrenal-insufficiency','acute-pain','chronic-pain','opioid-overdose','status-epilepticus','major-depression','anxiety','psychosis','bipolar-disorder','adhd','alzheimer-dementia','parkinsons-disease','migraine','insomnia','nausea-vomiting','gi-bleeding-pud','ibd','c-difficile','uti-pyelonephritis','sepsis','meningitis','fungal-infection','anemia','rheumatoid-arthritis','anaphylaxis']);
const validAdverseClusters = new Set(['nephrotoxicity','hepatotoxicity','qt-prolongation','cardiotoxicity','myelosuppression','peripheral-neuropathy','cns-neurotoxicity','ototoxicity','pulmonary-toxicity','teratogenicity','hyperkalemia','hypokalemia','hyponatremia','hypoglycemia','hyperglycemia','osteoporosis','serotonin-syndrome','nms','anticholinergic-toxidrome','opioid-toxidrome','bleeding','thrombosis','anaphylaxis','sjs-ten','dress','infusion-reactions','extrapyramidal','weight-gain','hyperlipidemia','drug-induced-lupus']);
const validInteractions = new Set(['cyp-inhibition','cyp-induction','transporter-interactions','pd-additive-toxicity','pd-antagonism','food-drug','protein-binding']);

// Mechanism family → target page slug mapping (maps granular mechanism tags to broad target pages)
const mechToTargetPage: Record<string, string> = {
  // Adrenergic
  'adrenergic-receptor-agonism': 'gpcr-adrenergic', 'alpha-adrenergic': 'gpcr-adrenergic',
  'beta-adrenergic': 'gpcr-adrenergic', 'non-selective-beta-blockade': 'gpcr-adrenergic',
  'beta1-selective-blockade': 'gpcr-adrenergic', 'beta1-blockade': 'gpcr-adrenergic',
  'beta-blockade': 'gpcr-adrenergic', 'alpha1-blockade': 'gpcr-adrenergic',
  'alpha2-agonism': 'gpcr-adrenergic', 'alpha1-agonism': 'gpcr-adrenergic',
  'beta2-agonism': 'gpcr-adrenergic', 'beta1-agonism': 'gpcr-adrenergic',
  'mixed-adrenergic-blockade': 'gpcr-adrenergic', 'vasopressin-receptor-agonism': 'gpcr-adrenergic',
  // Cholinergic
  'ache-inhibition': 'gpcr-cholinergic', 'muscarinic-antagonism': 'gpcr-cholinergic',
  'muscarinic-agonism': 'gpcr-cholinergic', 'nicotinic-agonism': 'gpcr-cholinergic',
  'nicotinic-antagonism': 'gpcr-cholinergic', 'muscarinic-antagonism-bronchodilation': 'gpcr-cholinergic',
  'nmj-blockade': 'gpcr-cholinergic', 'ach-release-stimulation': 'gpcr-cholinergic',
  // Opioid
  'mu-opioid-agonism': 'gpcr-opioid', 'mu-opioid-antagonism': 'gpcr-opioid',
  'mu-opioid-partial-agonism': 'gpcr-opioid', 'opioid-receptor-agonism': 'gpcr-opioid',
  'kappa-opioid': 'gpcr-opioid', 'opioid-antagonism': 'gpcr-opioid',
  // Histamine
  'h1-antagonism': 'gpcr-histamine', 'h2-antagonism': 'gpcr-histamine',
  'h1-blockade': 'gpcr-histamine', 'h2-blockade': 'gpcr-histamine',
  // Angiotensin
  'ace-inhibition': 'enzyme-ace', 'at1-blockade': 'gpcr-angiotensin',
  'neprilysin-inhibition': 'enzyme-ace', 'renin-inhibition': 'gpcr-angiotensin',
  // Dopamine
  'd2-antagonism': 'gpcr-dopamine', 'd2-partial-agonism': 'gpcr-dopamine',
  'dopamine-agonism': 'gpcr-dopamine', 'dopamine-antagonism': 'gpcr-dopamine',
  'd2-blockade': 'gpcr-dopamine', 'dopamine-precursor': 'gpcr-dopamine',
  'dopa-decarboxylase-inhibition': 'gpcr-dopamine', 'mao-b-inhibition': 'gpcr-dopamine',
  'comt-inhibition': 'gpcr-dopamine',
  // Serotonin
  '5-ht-reuptake-inhibition': 'gpcr-serotonin', 'sert-inhibition': 'gpcr-serotonin',
  '5-ht3-antagonism': 'gpcr-serotonin', '5-ht1a-partial-agonism': 'gpcr-serotonin',
  '5-ht2a-antagonism': 'gpcr-serotonin', '5-ht-modulation': 'gpcr-serotonin',
  '5-ht4-receptor-agonism': 'gpcr-serotonin', '5-ht1b-agonism': 'gpcr-serotonin',
  '5-ht1d-agonism': 'gpcr-serotonin', '5ht1b-1d-agonism': 'gpcr-serotonin',
  '5-ht1f-agonism': 'gpcr-serotonin',
  // Ion channels
  'gaba-a-modulation': 'ligand-gated-channels', 'gaba-a-receptor-agonism': 'ligand-gated-channels',
  'nmda-antagonism': 'ligand-gated-channels', 'glycine-receptor-inhibition': 'ligand-gated-channels',
  'nicotinic-receptor-modulation': 'ligand-gated-channels',
  'na-channel-blockade': 'voltage-gated-sodium', 'sodium-channel-blockade': 'voltage-gated-sodium',
  'voltage-gated-na-channel-blockade': 'voltage-gated-sodium',
  'l-type-calcium-channel-blockade': 'voltage-gated-calcium', 'ca-channel-blockade': 'voltage-gated-calcium',
  'calcium-channel-blockade': 'voltage-gated-calcium',
  'k-channel-blockade': 'voltage-gated-potassium', 'herg-channel-blockade': 'voltage-gated-potassium',
  'k-channel-opening': 'voltage-gated-potassium', 'katp-channel-opening': 'voltage-gated-potassium',
  'av-node-slowing': 'voltage-gated-calcium',
  // Nuclear receptors
  'glucocorticoid-receptor-agonism': 'nuclear-receptors', 'mineralocorticoid-receptor-agonism': 'nuclear-receptors',
  'androgen-receptor-antagonism': 'nuclear-receptors', 'estrogen-receptor-modulation': 'nuclear-receptors',
  'thyroid-hormone-replacement': 'nuclear-receptors', 'ppar-agonism': 'nuclear-receptors',
  'glucocorticoid-receptor': 'nuclear-receptors', 'mineralocorticoid-receptor-antagonism': 'nuclear-receptors',
  'retinoid-receptor-agonism': 'nuclear-receptors',
  // RTKs / kinases
  'bcr-abl-inhibition': 'receptor-tyrosine-kinases', 'egfr-inhibition': 'receptor-tyrosine-kinases',
  'vegfr-inhibition': 'receptor-tyrosine-kinases', 'rtk-inhibition': 'receptor-tyrosine-kinases',
  'her2-inhibition': 'receptor-tyrosine-kinases', 'multikinase-inhibition': 'receptor-tyrosine-kinases',
  'braf-inhibition': 'serine-threonine-kinases', 'mek-inhibition': 'serine-threonine-kinases',
  'cdk4-6-inhibition': 'serine-threonine-kinases', 'mtor-inhibition': 'serine-threonine-kinases',
  'jak-inhibition': 'serine-threonine-kinases', 'pi3k-inhibition': 'serine-threonine-kinases',
  'btk-inhibition': 'serine-threonine-kinases', 'jak1-2-inhibition': 'serine-threonine-kinases',
  // Enzymes
  'hmg-coa-inhibition': 'enzyme-hmgcoa', 'hmgcoa-inhibition': 'enzyme-hmgcoa',
  'cox-inhibition': 'enzyme-cox', 'cox-1-2-inhibition': 'enzyme-cox', 'cox-2-inhibition': 'enzyme-cox',
  'pde5-inhibition': 'enzyme-pde', 'pde3-inhibition': 'enzyme-pde', 'pde4-inhibition': 'enzyme-pde',
  'thymidylate-synthase-inhibition': 'enzyme-thymidylate', 'dna-polymerase-inhibition': 'enzyme-thymidylate',
  // Transporters
  'sert-inhibition': 'transporter-sert-dat-net', 'dat-inhibition': 'transporter-sert-dat-net',
  'net-inhibition': 'transporter-sert-dat-net', 'serotonin-reuptake-inhibition': 'transporter-sert-dat-net',
  'norepinephrine-reuptake-inhibition': 'transporter-sert-dat-net', 'dopamine-reuptake-inhibition': 'transporter-sert-dat-net',
  'sglt2-inhibition': 'transporter-pgp', 'p-gp-inhibition': 'transporter-pgp',
  'oatp-inhibition': 'transporter-pgp',
  // Structural
  'tubulin-polymerization-inhibition': 'structural-tubulin', 'tubulin-stabilization': 'structural-tubulin',
  'microtubule-stabilization': 'structural-tubulin', 'microtubule-inhibition': 'structural-tubulin',
  'topoisomerase-inhibition': 'structural-dna', 'dna-cross-linking': 'structural-dna',
  'dna-alkylation': 'structural-dna', 'dna-intercalation': 'structural-dna',
  'dna-strand-break': 'structural-dna',
};

// Map a mechanism_family value to a valid target page slug
function mapMechToTarget(val: string): string | null {
  const slug = val.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  if (validMechanismTargets.has(slug)) return slug;
  const mapped = mechToTargetPage[slug];
  if (mapped) return mapped;
  // Pattern-based fallbacks
  if (/adren|catecholamine|sympath/.test(slug)) return 'gpcr-adrenergic';
  if (/cholinerg|muscarin|nicotinic|acheinhibit/.test(slug)) return 'gpcr-cholinergic';
  if (/opioid|morphin/.test(slug)) return 'gpcr-opioid';
  if (/histamin|h1|h2/.test(slug)) return 'gpcr-histamine';
  if (/angiotensin|at1|renin/.test(slug)) return 'gpcr-angiotensin';
  if (/dopamin|d2|d1/.test(slug)) return 'gpcr-dopamine';
  if (/serotonin|5ht|sert/.test(slug)) return 'gpcr-serotonin';
  if (/gaba|benzo|nmda|ligand/.test(slug)) return 'ligand-gated-channels';
  if (/sodium.channel|na.channel/.test(slug)) return 'voltage-gated-sodium';
  if (/calcium.channel|ca.channel|l.type/.test(slug)) return 'voltage-gated-calcium';
  if (/potassium.channel|k.channel|herg/.test(slug)) return 'voltage-gated-potassium';
  if (/nuclear|glucocorticoid|mineralo|androgen|estrogen|thyroid|ppar/.test(slug)) return 'nuclear-receptors';
  if (/rtk|egfr|her2|vegfr|bcr.abl|tyrosine.kinase/.test(slug)) return 'receptor-tyrosine-kinases';
  if (/braf|mek|cdk|mtor|jak|pi3k|btk|serine|threonine|kinase/.test(slug)) return 'serine-threonine-kinases';
  if (/ace|angiotensin.convert|neprilysin/.test(slug)) return 'enzyme-ace';
  if (/cox|prostaglandin|nsaid/.test(slug)) return 'enzyme-cox';
  if (/hmg|statin|cholesterol.synth/.test(slug)) return 'enzyme-hmgcoa';
  if (/pde\d?/.test(slug)) return 'enzyme-pde';
  if (/thymidylate|dna.polym|viral.polym/.test(slug)) return 'enzyme-thymidylate';
  if (/sert|dat|net|reuptake/.test(slug)) return 'transporter-sert-dat-net';
  if (/sglt|pgp|oatp|transport/.test(slug)) return 'transporter-pgp';
  if (/tubulin|microtubule/.test(slug)) return 'structural-tubulin';
  if (/dna|topoisom|alkylat|intercalat|cross.link/.test(slug)) return 'structural-dna';
  return null;
}

// Validate and map schema membership values to page slugs
function resolveSchemaLinks(key: string, values: string[]): Array<{slug: string, label: string}> {
  return values.flatMap(v => {
    const slug = v.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
    const label = v.replace(/-/g, ' ');
    if (key === 'organ_system' && validOrganSystems.has(slug)) return [{ slug, label }];
    if (key === 'therapeutic_class' && validTherapeuticClasses.has(slug)) return [{ slug, label }];
    if (key === 'mechanism_family') {
      const target = mapMechToTarget(v);
      if (target) return [{ slug: target, label: v.replace(/-/g, ' ') }];
    }
    if (key === 'prototype_class') return [{ slug, label }]; // dynamic, always try
    if (key === 'presentation_cluster' && validPresentations.has(slug)) return [{ slug, label }];
    if (key === 'adverse_cluster' && validAdverseClusters.has(slug)) return [{ slug, label }];
    if (key === 'interaction_cluster' && validInteractions.has(slug)) return [{ slug, label }];
    return [];
  }).filter((item, idx, arr) => arr.findIndex(x => x.slug === item.slug) === idx); // dedupe
}

const pkRows = [
  { label: 'Absorption', value: drug.pharmacokinetics?.absorption },
  { label: 'Distribution', value: drug.pharmacokinetics?.distribution },
  { label: 'Metabolism', value: drug.pharmacokinetics?.metabolism },
  { label: 'Excretion', value: drug.pharmacokinetics?.excretion },
  { label: 'Half-life', value: drug.pharmacokinetics?.half_life },
  { label: 'Onset', value: drug.pharmacokinetics?.onset },
  { label: 'Peak', value: drug.pharmacokinetics?.peak },
  { label: 'Duration', value: drug.pharmacokinetics?.duration },
  { label: 'Protein binding', value: drug.pharmacokinetics?.protein_binding },
  { label: 'Volume of distribution', value: drug.pharmacokinetics?.vd },
].filter(r => r.value);
---
<DrugProfileLayout title={`${drug.generic_name} — PharmRef`} drug={drug}>
  <Nav />
  <main class="container mx-auto px-4 py-8 max-w-5xl">
    
    <!-- Header card -->
    <div class="card bg-base-100 shadow-md mb-8">
      <div class="card-body">
        <div class="flex flex-wrap items-start gap-3 mb-2">
          <h1 class="text-4xl font-serif font-bold capitalize">{drug.generic_name}</h1>
          {drug.prototype_for && <span class="badge badge-success badge-lg">PROTOTYPE</span>}
          {drug.ismp_high_alert && <span class="badge badge-error badge-lg">HIGH ALERT</span>}
          {drug.black_box_warnings && drug.black_box_warnings.length > 0 && (
            <span class="badge badge-error badge-outline badge-lg">⬛ BLACK BOX WARNING</span>
          )}
          {drug.beers_criteria && <span class="badge badge-warning badge-lg">BEERS CRITERIA</span>}
        </div>
        
        {drug.brand_names && drug.brand_names.length > 0 && (
          <p class="text-base-content/70 text-sm mb-2">
            <span class="font-semibold">Brand names:</span> {drug.brand_names.join(', ')}
          </p>
        )}
        
        <div class="flex flex-wrap gap-2 mb-3">
          <span class="badge badge-outline">{drug.drug_class}</span>
          {drug.subclass && drug.subclass !== drug.drug_class && (
            <span class="badge badge-ghost">{drug.subclass}</span>
          )}
          {drug.organ_systems?.map((sys: string) => (
            <a href={`${base}schemas/01-organ-systems/${sys}`} class="badge badge-outline badge-primary hover:badge-primary transition-colors capitalize">{sys.replace(/-/g, ' ')}</a>
          ))}
        </div>

        {prototypeDrug && (
          <p class="text-sm text-base-content/70">
            Class variation of <a href={`${base}drugs/${prototypeDrug.id}`} class="link link-primary font-semibold capitalize">{prototypeDrug.generic_name}</a> (prototype)
          </p>
        )}
      </div>
    </div>

    <!-- ISMP High Alert callout -->
    {drug.ismp_high_alert && (
      <div class="alert alert-error mb-6 shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
        <div>
          <h3 class="font-bold">ISMP High-Alert Medication</h3>
          <div class="text-sm">This drug has been identified by the Institute for Safe Medication Practices (ISMP) as a high-alert medication that bears a heightened risk of causing significant harm when used in error. Independent double-checks, clinical decision support, and standardized concentrations are recommended wherever feasible.</div>
        </div>
      </div>
    )}

    <!-- Black Box Warning -->
    {drug.black_box_warnings && drug.black_box_warnings.length > 0 && (
      <div class="alert alert-error mb-6 shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
        <div>
          <h3 class="font-bold">⬛ Black Box Warning(s)</h3>
          <ul class="text-sm mt-1 list-disc list-inside">
            {drug.black_box_warnings.map((w: string) => <li>{w}</li>)}
          </ul>
        </div>
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main content column -->
      <div class="lg:col-span-2 space-y-8">

        <!-- Mechanism of Action -->
        <section>
          <h2 class="text-2xl font-serif font-bold mb-3 border-b border-base-300 pb-2">Mechanism of Action</h2>
          <div class="space-y-3">
            <p class="text-base leading-relaxed">{drug.mechanism_summary}</p>
            {drug.mechanism_targets && drug.mechanism_targets.length > 0 && (
              <p class="text-sm text-base-content/70">
                <span class="font-semibold">Target(s):</span> {drug.mechanism_targets.join('; ')}
              </p>
            )}
          </div>
        </section>

        <!-- Pharmacokinetics -->
        {pkRows.length > 0 && (
          <section>
            <h2 class="text-2xl font-serif font-bold mb-3 border-b border-base-300 pb-2">Pharmacokinetics</h2>
            <div class="overflow-x-auto mb-4">
              <table class="table table-zebra table-sm w-full">
                <tbody>
                  {pkRows.map(row => (
                    <tr>
                      <td class="font-semibold text-base-content/70 w-36">{row.label}</td>
                      <td class="font-mono text-sm">{row.value}</td>
                    </tr>
                  ))}
                  {drug.renal_dose_adjustment && (
                    <tr>
                      <td class="font-semibold text-base-content/70">Renal adjustment</td>
                      <td><span class="badge badge-warning badge-sm">Required</span></td>
                    </tr>
                  )}
                  {drug.hepatic_dose_adjustment && (
                    <tr>
                      <td class="font-semibold text-base-content/70">Hepatic adjustment</td>
                      <td><span class="badge badge-warning badge-sm">Required</span></td>
                    </tr>
                  )}
                  {drug.tdm_required && (
                    <tr>
                      <td class="font-semibold text-base-content/70">TDM required</td>
                      <td><span class="badge badge-info badge-sm">Yes</span></td>
                    </tr>
                  )}
                </tbody>
              </table>
            </div>
            <div class="flex gap-4 text-sm flex-wrap">
              {drug.pregnancy_safety && <span><span class="font-semibold">Pregnancy:</span> {drug.pregnancy_safety}</span>}
              {drug.lactation_safety && <span><span class="font-semibold">Lactation:</span> {drug.lactation_safety}</span>}
            </div>
          </section>
        )}

        <!-- Indications -->
        {drug.indications && drug.indications.length > 0 && (
          <section>
            <h2 class="text-2xl font-serif font-bold mb-3 border-b border-base-300 pb-2">Indications</h2>
            <p class="text-base leading-relaxed">{drug.indications.join('; ')}.</p>
          </section>
        )}

        <!-- Contraindications -->
        {drug.contraindications && drug.contraindications.length > 0 && (
          <section>
            <h2 class="text-2xl font-serif font-bold mb-3 border-b border-base-300 pb-2">Contraindications & Precautions</h2>
            <p class="text-base leading-relaxed">{drug.contraindications.join('; ')}.</p>
          </section>
        )}

        <!-- Adverse Effects -->
        {drug.adverse_effects && (
          <section>
            <h2 class="text-2xl font-serif font-bold mb-3 border-b border-base-300 pb-2">Adverse Effects</h2>
            <div class="space-y-3">
              {drug.adverse_effects.common && drug.adverse_effects.common.length > 0 && (
                <div>
                  <h3 class="font-semibold text-base-content/80 mb-1">Common</h3>
                  <p class="text-sm">{drug.adverse_effects.common.join(', ')}.</p>
                </div>
              )}
              {drug.adverse_effects.serious && drug.adverse_effects.serious.length > 0 && (
                <div class="alert alert-warning shadow-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                  <div>
                    <h3 class="font-bold text-sm">Serious Adverse Effects</h3>
                    <p class="text-sm">{drug.adverse_effects.serious.join('; ')}.</p>
                  </div>
                </div>
              )}
            </div>
          </section>
        )}

        <!-- Drug Interactions -->
        {drug.drug_interactions && drug.drug_interactions.length > 0 && (
          <section>
            <h2 class="text-2xl font-serif font-bold mb-3 border-b border-base-300 pb-2">Drug Interactions</h2>
            <div class="overflow-x-auto">
              <table class="table table-zebra table-sm w-full">
                <thead>
                  <tr>
                    <th>Drug / Class</th>
                    <th>Mechanism</th>
                    <th>Severity</th>
                  </tr>
                </thead>
                <tbody>
                  {drug.drug_interactions.map((interaction: any) => (
                    <tr>
                      <td class="font-medium text-sm capitalize">{interaction.drug}</td>
                      <td class="text-sm text-base-content/80">{interaction.mechanism}</td>
                      <td>
                        {interaction.severity === 'major' && <span class="badge badge-error badge-sm">Major</span>}
                        {interaction.severity === 'moderate' && <span class="badge badge-warning badge-sm">Moderate</span>}
                        {interaction.severity === 'minor' && <span class="badge badge-ghost badge-sm">Minor</span>}
                        {interaction.severity === 'beneficial' && <span class="badge badge-success badge-sm">Beneficial</span>}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}

        <!-- Nursing Considerations -->
        <section>
          <h2 class="text-2xl font-serif font-bold mb-3 border-b border-base-300 pb-2">Nursing Considerations</h2>
          {drug.ismp_high_alert && (
            <div class="alert alert-error mb-4 shadow-sm text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
              <p><strong>ISMP High-Alert Medication:</strong> This drug has been identified by ISMP as bearing a heightened risk of causing significant harm when used in error. Independent double-checks and standardized concentrations are recommended.</p>
            </div>
          )}
          {drug.nursing_considerations && drug.nursing_considerations.length > 0 ? (
            <div class="space-y-3">
              {drug.nursing_considerations.map((note: string) => (
                <div class="alert alert-info shadow-sm text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  <p>{note}</p>
                </div>
              ))}
            </div>
          ) : (
            <p class="text-base-content/60">See current package insert for nursing guidance.</p>
          )}
        </section>

        <!-- Clinical Pearls -->
        {drug.clinical_pearls && drug.clinical_pearls.length > 0 && (
          <section>
            <h2 class="text-2xl font-serif font-bold mb-3 border-b border-base-300 pb-2">Clinical Pearls</h2>
            <div class="space-y-3">
              {drug.clinical_pearls.map((pearl: string) => (
                <div class="alert alert-success shadow-sm text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  <p>{pearl}</p>
                </div>
              ))}
            </div>
          </section>
        )}

      </div>

      <!-- Sidebar -->
      <div class="space-y-6">

        <!-- Schema Membership Panel -->
        <div class="card bg-base-200 shadow-sm">
          <div class="card-body p-4">
            <h3 class="font-bold text-base mb-3">Schema Membership</h3>
            <div class="space-y-2">
              {schemaMaps.map(sm => {
                const rawValues = Array.isArray(drug.schema_memberships?.[sm.key])
                  ? drug.schema_memberships[sm.key]
                  : drug.schema_memberships?.[sm.key]
                    ? [drug.schema_memberships[sm.key]]
                    : [];
                const links = resolveSchemaLinks(sm.key, rawValues);
                if (links.length === 0) return null;
                return (
                  <div>
                    <div class="text-xs font-semibold text-base-content/60 uppercase mb-1">{sm.label}</div>
                    <div class="flex flex-wrap gap-1">
                      {links.map(({ slug, label }) => (
                        <a href={`${base}${sm.base}/${slug}`} class="badge badge-outline badge-sm hover:badge-primary capitalize">
                          {label}
                        </a>
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>

        <!-- Safety Flags -->
        <div class="card bg-base-200 shadow-sm">
          <div class="card-body p-4">
            <h3 class="font-bold text-base mb-3">Safety Flags</h3>
            <div class="space-y-1 text-sm">
              <div class="flex items-center justify-between">
                <span>ISMP High Alert</span>
                {drug.ismp_high_alert ? <span class="badge badge-error badge-sm">Yes</span> : <span class="badge badge-ghost badge-sm">No</span>}
              </div>
              <div class="flex items-center justify-between">
                <span>Beers Criteria</span>
                {drug.beers_criteria ? <span class="badge badge-warning badge-sm">Yes</span> : <span class="badge badge-ghost badge-sm">No</span>}
              </div>
              <div class="flex items-center justify-between">
                <span>TDM Required</span>
                {drug.tdm_required ? <span class="badge badge-info badge-sm">Yes</span> : <span class="badge badge-ghost badge-sm">No</span>}
              </div>
              <div class="flex items-center justify-between">
                <span>Renal Adjustment</span>
                {drug.renal_dose_adjustment ? <span class="badge badge-warning badge-sm">Yes</span> : <span class="badge badge-ghost badge-sm">No</span>}
              </div>
              <div class="flex items-center justify-between">
                <span>Hepatic Adjustment</span>
                {drug.hepatic_dose_adjustment ? <span class="badge badge-warning badge-sm">Yes</span> : <span class="badge badge-ghost badge-sm">No</span>}
              </div>
              <div class="flex items-center justify-between">
                <span>Guideline Update</span>
                {drug.guideline_update_flag ? <span class="badge badge-warning badge-sm">Recent</span> : <span class="badge badge-ghost badge-sm">Current</span>}
              </div>
            </div>
          </div>
        </div>

        <!-- Related Drugs Panel -->
        {relatedDrugs.length > 0 && (
          <div class="card bg-base-200 shadow-sm">
            <div class="card-body p-4">
              <h3 class="font-bold text-base mb-3">Related Drugs</h3>
              <div class="space-y-2">
                {relatedDrugs.map((rd: any) => (
                  <a href={`${base}drugs/${rd.id}`} class="block p-2 rounded hover:bg-base-300 transition-colors">
                    <div class="flex items-center gap-1">
                      <span class="text-sm font-medium capitalize">{rd.generic_name}</span>
                      {rd.prototype_for && <span class="badge badge-success badge-xs">P</span>}
                    </div>
                    <div class="text-xs text-base-content/60">{rd.subclass || rd.drug_class}</div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        )}

      </div>
    </div>
  </main>
</DrugProfileLayout>
