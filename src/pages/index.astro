---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import drugsData from '../../data/drugs.json';

const base = import.meta.env.BASE_URL;
const drugs = drugsData as any[];
const dayOfYear = Math.floor((Date.now() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86400000);
const featuredDrug = drugs[dayOfYear % drugs.length];
const ismpCount = drugs.filter((d: any) => d.ismp_high_alert).length;
const bbwCount = drugs.filter((d: any) => d.black_box_warnings && d.black_box_warnings.length > 0).length;
---
<BaseLayout title="PharmRef - Pharmacology Reference">
  <Nav />
  <section class="bg-base-200 py-16 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-serif font-bold mb-4 text-base-content">PharmRef</h1>
      <p class="text-xl text-base-content/80 mb-2 max-w-2xl mx-auto">
        A comprehensive pharmacology reference covering the top 500 clinical medications through nine distinct educational schemas.
      </p>
      <p class="text-base text-base-content/60 mb-8">
        Designed for USMLE Steps 1-3, NCLEX, and advanced clinical pharmacology education.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href={`${base}drug-index`} class="btn btn-primary btn-lg">Browse 500 Drugs</a>
        <a href={`${base}schemas/01-organ-systems/`} class="btn btn-outline btn-lg">Explore Schemas</a>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 py-8 max-w-5xl">
    <div class="alert alert-info shadow-md">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      <div>
        <span class="font-bold">Start Here:</span> New to PharmRef? Begin with <a href={`${base}schemas/05-prototype-class/`} class="link font-semibold">Schema 5 - Prototype + Class</a> to build a strong pharmacological framework. Then explore <a href={`${base}schemas/01-organ-systems/`} class="link font-semibold">Organ Systems</a> for clinical context, and <a href={`${base}schemas/09-drug-interactions/`} class="link font-semibold">Drug Interactions</a> for patient safety.
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 pb-12 max-w-6xl">
    <h2 class="text-2xl font-serif font-bold mb-6 text-center">Nine Educational Schemas</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <a href={`${base}schemas/01-organ-systems/`} class="card card-compact bg-base-100 border border-base-200 hover:shadow-lg transition-shadow group">
        <div class="card-body">
          <div class="flex items-center gap-2 mb-1"><span class="badge badge-outline text-xs font-mono">Schema 1</span></div>
          <h3 class="card-title text-base font-semibold font-serif group-hover:text-primary">Organ Systems</h3>
          <p class="text-sm text-base-content/70">Drugs organized by the body system they target: cardiovascular, CNS, respiratory, and 12 more.</p>
        </div>
      </a>
      <a href={`${base}schemas/02-therapeutic-classes/`} class="card card-compact bg-base-100 border border-base-200 hover:shadow-lg transition-shadow group">
        <div class="card-body">
          <div class="flex items-center gap-2 mb-1"><span class="badge badge-outline text-xs font-mono">Schema 2</span></div>
          <h3 class="card-title text-base font-semibold font-serif group-hover:text-primary">Therapeutic Classes</h3>
          <p class="text-sm text-base-content/70">Organized by mechanism family: adrenergic, cholinergic, ion-channel, enzyme inhibitors, and more.</p>
        </div>
      </a>
      <a href={`${base}schemas/03-organ-by-class/`} class="card card-compact bg-base-100 border border-base-200 hover:shadow-lg transition-shadow group">
        <div class="card-body">
          <div class="flex items-center gap-2 mb-1"><span class="badge badge-outline text-xs font-mono">Schema 3</span></div>
          <h3 class="card-title text-base font-semibold font-serif group-hover:text-primary">Organ x Class Matrix</h3>
          <p class="text-sm text-base-content/70">Interactive cross-reference matrix linking organ systems to therapeutic classes.</p>
        </div>
      </a>
      <a href={`${base}schemas/04-mechanism-first/`} class="card card-compact bg-base-100 border border-base-200 hover:shadow-lg transition-shadow group">
        <div class="card-body">
          <div class="flex items-center gap-2 mb-1"><span class="badge badge-outline text-xs font-mono">Schema 4</span></div>
          <h3 class="card-title text-base font-semibold font-serif group-hover:text-primary">Mechanism-First</h3>
          <p class="text-sm text-base-content/70">Start with the molecular target: GPCRs, ion channels, nuclear receptors, kinases, enzymes.</p>
        </div>
      </a>
      <a href={`${base}schemas/05-prototype-class/`} class="card card-compact bg-base-100 border border-base-200 hover:shadow-lg transition-shadow group">
        <div class="card-body">
          <div class="flex items-center gap-2 mb-1"><span class="badge badge-outline text-xs font-mono">Schema 5</span></div>
          <h3 class="card-title text-base font-semibold font-serif group-hover:text-primary">Prototype + Class</h3>
          <p class="text-sm text-base-content/70">Learn the prototype drug deeply, then understand class variations along four axes.</p>
        </div>
      </a>
      <a href={`${base}schemas/06-adme/`} class="card card-compact bg-base-100 border border-base-200 hover:shadow-lg transition-shadow group">
        <div class="card-body">
          <div class="flex items-center gap-2 mb-1"><span class="badge badge-outline text-xs font-mono">Schema 6</span></div>
          <h3 class="card-title text-base font-semibold font-serif group-hover:text-primary">ADME</h3>
          <p class="text-sm text-base-content/70">Absorption, distribution, CYP metabolism, excretion, and special populations.</p>
        </div>
      </a>
      <a href={`${base}schemas/07-clinical-presentations/`} class="card card-compact bg-base-100 border border-base-200 hover:shadow-lg transition-shadow group">
        <div class="card-body">
          <div class="flex items-center gap-2 mb-1"><span class="badge badge-outline text-xs font-mono">Schema 7</span></div>
          <h3 class="card-title text-base font-semibold font-serif group-hover:text-primary">Clinical Presentations</h3>
          <p class="text-sm text-base-content/70">Drugs organized by the clinical scenario: ACS, heart failure, sepsis, status epilepticus.</p>
        </div>
      </a>
      <a href={`${base}schemas/08-adverse-effects/`} class="card card-compact bg-base-100 border border-base-200 hover:shadow-lg transition-shadow group">
        <div class="card-body">
          <div class="flex items-center gap-2 mb-1"><span class="badge badge-outline text-xs font-mono">Schema 8</span></div>
          <h3 class="card-title text-base font-semibold font-serif group-hover:text-primary">Adverse Effects</h3>
          <p class="text-sm text-base-content/70">Drug toxidrome clusters: nephrotoxicity, QT prolongation, serotonin syndrome, and more.</p>
        </div>
      </a>
      <a href={`${base}schemas/09-drug-interactions/`} class="card card-compact bg-base-100 border border-base-200 hover:shadow-lg transition-shadow group">
        <div class="card-body">
          <div class="flex items-center gap-2 mb-1"><span class="badge badge-outline text-xs font-mono">Schema 9</span></div>
          <h3 class="card-title text-base font-semibold font-serif group-hover:text-primary">Drug Interactions</h3>
          <p class="text-sm text-base-content/70">CYP inhibition, induction, pharmacodynamic interactions, food-drug, and protein binding.</p>
        </div>
      </a>
    </div>
  </section>

  <section class="bg-base-200 py-10 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-xl font-serif font-bold mb-4 text-center">Drug of the Day</h2>
      <div class="card bg-base-100 shadow-md">
        <div class="card-body">
          <div class="flex flex-wrap items-center gap-2 mb-1">
            <h3 class="card-title text-2xl font-serif capitalize">{featuredDrug.generic_name}</h3>
            {featuredDrug.prototype_for && <span class="badge badge-success">PROTOTYPE</span>}
            {featuredDrug.ismp_high_alert && <span class="badge badge-error">HIGH ALERT</span>}
          </div>
          <p class="text-sm text-base-content/60 mb-2">{featuredDrug.brand_names?.join(', ')}</p>
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="badge badge-outline">{featuredDrug.drug_class}</span>
          </div>
          <p class="text-sm text-base-content/80 mb-4">{featuredDrug.mechanism_summary}</p>
          <div class="card-actions justify-end">
            <a href={`${base}drugs/${featuredDrug.id}`} class="btn btn-primary btn-sm">View Full Profile</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 py-10 max-w-4xl">
    <div class="stats stats-vertical sm:stats-horizontal shadow w-full">
      <div class="stat">
        <div class="stat-title">Total Drugs</div>
        <div class="stat-value text-primary">{drugs.length}</div>
        <div class="stat-desc">Fully profiled</div>
      </div>
      <div class="stat">
        <div class="stat-title">Educational Schemas</div>
        <div class="stat-value text-secondary">9</div>
        <div class="stat-desc">Parallel organizations</div>
      </div>
      <div class="stat">
        <div class="stat-title">ISMP High-Alert</div>
        <div class="stat-value text-error">{ismpCount}</div>
        <div class="stat-desc">High-alert medications</div>
      </div>
      <div class="stat">
        <div class="stat-title">Black Box Warnings</div>
        <div class="stat-value text-warning">{bbwCount}</div>
        <div class="stat-desc">Drugs with BBW</div>
      </div>
    </div>
  </section>
</BaseLayout>
