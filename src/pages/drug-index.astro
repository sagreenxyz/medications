---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import DrugIndexFilter from '../components/DrugIndexFilter.svelte';
import drugsData from '../../data/drugs.json';

const base = import.meta.env.BASE_URL;
const drugs = (drugsData as any[]).sort((a, b) => a.generic_name.localeCompare(b.generic_name));
---
<BaseLayout title="Drug Index — PharmRef">
  <Nav />
  <main class="container mx-auto px-4 py-8 max-w-6xl">
    <h1 class="text-3xl font-serif font-bold mb-2">Drug Index</h1>
    <p class="text-base-content/70 mb-6">Browse all {drugs.length} drugs alphabetically. Use the filters below to narrow by organ system, drug class, or safety flags.</p>

    <DrugIndexFilter client:load drugs={drugs} base={base} />
  </main>
</BaseLayout>
