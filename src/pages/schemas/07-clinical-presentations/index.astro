  { slug: 'parkinsons-disease', label: "Parkinson's Disease", system: 'Neurology', icon: '🧠' },
  { slug: 'migraine', label: 'Migraine', system: 'Neurology', icon: '🧠' },
  { slug: 'insomnia', label: 'Insomnia', system: 'Neurology', icon: '🧠' },
  { slug: 'nausea-vomiting', label: 'Nausea / Vomiting / CINV', system: 'GI', icon: '🫄' },
