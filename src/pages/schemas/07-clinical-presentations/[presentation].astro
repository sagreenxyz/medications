    { slug: 'hypothyroidism', label: 'Hypothyroidism', keywords: ['hypothyroidism','thyroid replacement','myxedema'] },
    { slug: 'hyperthyroidism', label: 'Hyperthyroidism', keywords: ['hyperthyroidism','thyrotoxicosis','Graves'] },
    { slug: 'adrenal-insufficiency', label: 'Adrenal Insufficiency', keywords: ['adrenal insufficiency','Addison','adrenal crisis'] },
    { slug: 'acute-pain', label: 'Acute Pain', keywords: ['acute pain','pain','analgesia','post-operative'] },
    { slug: 'chronic-pain', label: 'Chronic Pain', keywords: ['chronic pain','neuropathic pain','fibromyalgia'] },
    { slug: 'opioid-overdose', label: 'Opioid Overdose / Reversal', keywords: ['opioid overdose','overdose','naloxone','opioid reversal'] },
    { slug: 'status-epilepticus', label: 'Status Epilepticus', keywords: ['status epilepticus','seizure','epilepsy','anticonvulsant'] },
    { slug: 'major-depression', label: 'Major Depression', keywords: ['depression','MDD','antidepressant','major depressive'] },
    { slug: 'anxiety', label: 'Generalized Anxiety Disorder', keywords: ['anxiety','GAD','anxiolytic','panic'] },
    { slug: 'psychosis', label: 'Acute Psychosis / Schizophrenia', keywords: ['psychosis','schizophrenia','antipsychotic'] },
    { slug: 'bipolar-disorder', label: 'Bipolar Disorder', keywords: ['bipolar','mania','mood stabilizer'] },
    { slug: 'adhd', label: 'ADHD', keywords: ['ADHD','attention deficit','stimulant','hyperactivity'] },
    { slug: 'alzheimer-dementia', label: "Alzheimer's Dementia", keywords: ['Alzheimer','dementia','cognitive decline'] },
    { slug: 'parkinsons-disease', label: "Parkinson's Disease", keywords: ['Parkinson','dopamine','levodopa','parkinsonism'] },
    { slug: 'migraine', label: 'Migraine', keywords: ['migraine','headache','triptan','CGRP'] },
    { slug: 'insomnia', label: 'Insomnia', keywords: ['insomnia','sleep disorder','sedative-hypnotic'] },
    { slug: 'nausea-vomiting', label: 'Nausea / Vomiting / CINV', keywords: ['nausea','vomiting','CINV','antiemetic'] },
    { slug: 'gi-bleeding-pud', label: 'GI Bleeding / PUD / GERD', keywords: ['GI bleeding','peptic ulcer','PUD','GERD','acid suppression'] },
    { slug: 'ibd', label: 'Inflammatory Bowel Disease', keywords: ['IBD','Crohn','ulcerative colitis','inflammatory bowel'] },
    { slug: 'c-difficile', label: 'C. difficile Infection', keywords: ['C. difficile','C-diff','clostridioides'] },
    { slug: 'uti-pyelonephritis', label: 'UTI / Pyelonephritis', keywords: ['UTI','pyelonephritis','urinary tract','cystitis'] },
    { slug: 'sepsis', label: 'Sepsis / Bacteremia', keywords: ['sepsis','bacteremia','septicemia'] },
    { slug: 'meningitis', label: 'Bacterial Meningitis', keywords: ['meningitis','bacterial meningitis'] },
    { slug: 'fungal-infection', label: 'Invasive Fungal Infection', keywords: ['fungal infection','candidiasis','aspergillosis','antifungal'] },
    { slug: 'anemia', label: 'Anemia', keywords: ['anemia','iron deficiency','megaloblastic','erythropoietin'] },
    { slug: 'rheumatoid-arthritis', label: 'Rheumatoid Arthritis', keywords: ['rheumatoid arthritis','RA','DMARD'] },
    { slug: 'anaphylaxis', label: 'Anaphylaxis', keywords: ['anaphylaxis','anaphylactic','allergic emergency'] },
  ];
  return presData.map(p => {
    const kw = p.keywords.map(k => k.toLowerCase());
    const matched = drugs.filter(d => {
      const text = [
        ...(d.presentation_tags || []),
        ...(d.schema_memberships?.presentation_cluster || []),
        ...(d.indications || []),
      ].join(' ').toLowerCase();
      return kw.some(k => text.includes(k));
    });
    return {
      params: { presentation: p.slug },
      props: { label: p.label, drugs: matched, slug: p.slug },
    };
  });
}

const { label, drugs, slug } = Astro.props as { label: string; drugs: any[]; slug: string };
const base = import.meta.env.BASE_URL;
const prose = proseMap[slug] || null;

function tier(d: any, slug: string): string {
  const indications = ((d.indications || []) as string[]).join(' ').toLowerCase();
  const ptags = ((d.presentation_tags || []) as string[]).join(' ').toLowerCase();
  const kws = (presentations.find(p => p.slug === slug)?.tier1 || []).map((t: string) => t.toLowerCase());
  const cls = (d.drug_class || '').toLowerCase();
  const isFirst = kws.some(k => cls.includes(k) || indications.includes(k));
  if (isFirst) return 'First-line';
  if (ptags.includes(slug.replace(/-/g, ' ')) || ptags.includes(slug)) return 'Second-line';
  return 'Adjunct';
}
---
<SchemaLayout title={`${label} — Clinical Presentations`} schema="clinical-presentations" description={`Pharmacological management of ${label}: pathophysiology, drug selection, tiers, and nursing considerations`}>

  <div class="mb-2">
    <a href={`${base}schemas/07-clinical-presentations/`} class="text-sm text-base-content/60 hover:text-primary">← Schema 7: Clinical Presentations</a>
  </div>

  <div class="mb-8">
    <h1 class="text-4xl font-serif font-bold text-base-content mb-2">{label}</h1>
    <p class="text-base-content/60">{drugs.length} drug{drugs.length !== 1 ? 's' : ''} in this reference address this clinical presentation.</p>
  </div>

  {prose ? (
    <div class="prose max-w-none mb-10">
      <h2 class="text-2xl font-serif font-bold mb-3">Pathophysiology & Pharmacological Rationale</h2>
      <p>{prose.p1}</p>
      <h2 class="text-2xl font-serif font-bold mb-3 mt-6">First-Line Pharmacological Approach</h2>
      <p>{prose.p2}</p>
      <h2 class="text-2xl font-serif font-bold mb-3 mt-6">Second-Line & Adjunct Agents</h2>
      <p>{prose.p3}</p>
      <h2 class="text-2xl font-serif font-bold mb-3 mt-6">Monitoring & Nursing Key Points</h2>
      <p>{prose.p4}</p>
    </div>
  ) : (
    <div class="prose max-w-none mb-8">
      <p>Pharmacological management of <strong>{label}</strong> involves {drugs.length} agents across multiple drug classes, reflecting the complexity of the underlying pathophysiology and the range of available therapeutic targets. Consult current clinical guidelines (ACC/AHA, GINA, GOLD, ADA, IDSA as applicable) for evidence-based treatment algorithms and monitoring parameters specific to patient populations. The drugs listed below are organized by treatment tier and cross-referenced to individual drug profile pages for complete pharmacological detail.</p>
    </div>
  )}

  <!-- Treatment Tiers (Steps) -->
  <div class="mb-8">
    <h2 class="text-2xl font-serif font-bold mb-4">Treatment Hierarchy</h2>
    <ul class="steps steps-vertical lg:steps-horizontal w-full mb-6">
      <li class="step step-primary">First-line agents</li>
      <li class="step step-primary">Second-line agents</li>
      <li class="step">Adjunct / situational</li>
    </ul>
  </div>

  <!-- Drug Table -->
  <div class="mb-10">
    <h2 class="text-2xl font-serif font-bold mb-4">Drugs for {label}</h2>
    {drugs.length === 0 ? (
      <div class="alert alert-info">
        <span>No drugs in the database are specifically tagged for this presentation. Navigate to individual schema pages for related drug information.</span>
      </div>
    ) : (
      <div class="overflow-x-auto">
        <table class="table table-zebra w-full">
          <thead>
            <tr>
              <th>Drug</th>
              <th>Class</th>
              <th>Mechanism</th>
              <th>Tier</th>
            </tr>
          </thead>
          <tbody>
            {drugs.map((d: any) => (
              <tr class={d.ismp_high_alert ? 'border-l-4 border-error' : ''}>
                <td>
                  <a href={`${base}drugs/${d.id}/`} class="font-semibold text-primary hover:underline">{d.generic_name}</a>
                  {d.ismp_high_alert && <span class="badge badge-error badge-sm ml-1">HIGH ALERT</span>}
                  {d.beers_criteria && <span class="badge badge-warning badge-sm ml-1">BEERS</span>}
                </td>
                <td class="text-sm">{d.drug_class}</td>
                <td class="text-sm text-base-content/70 max-w-xs">{d.mechanism_summary ? d.mechanism_summary.slice(0, 100) + (d.mechanism_summary.length > 100 ? '...' : '') : '—'}</td>
                <td>
                  <span class={`badge badge-sm ${tier(d, slug) === 'First-line' ? 'badge-success' : tier(d, slug) === 'Second-line' ? 'badge-warning' : 'badge-ghost'}`}>
                    {tier(d, slug)}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <div class="alert alert-info mt-6">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
    <div>
      <p class="font-semibold">Cross-schema navigation</p>
      <p class="text-sm">
        Explore these drugs by mechanism in <a href={`${base}schemas/04-mechanism-first/`} class="link">Schema 4 (Mechanism-First)</a>,
        by adverse effects in <a href={`${base}schemas/08-adverse-effects/`} class="link">Schema 8</a>,
        or by drug interactions in <a href={`${base}schemas/09-drug-interactions/`} class="link">Schema 9</a>.
      </p>
    </div>
  </div>

</SchemaLayout>
