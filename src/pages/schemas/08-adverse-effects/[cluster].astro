    { slug: 'serotonin-syndrome', label: 'Serotonin Syndrome', keywords: ['serotonin syndrome','serotonin toxicity'] },
    { slug: 'nms', label: 'Neuroleptic Malignant Syndrome', keywords: ['neuroleptic malignant','NMS'] },
    { slug: 'anticholinergic-toxidrome', label: 'Anticholinergic Toxidrome', keywords: ['anticholinergic toxidrome','anticholinergic effects','antimuscarinic'] },
    { slug: 'opioid-toxidrome', label: 'Opioid Toxidrome', keywords: ['opioid toxidrome','opioid overdose','respiratory depression'] },
    { slug: 'bleeding', label: 'Bleeding / Hemorrhage', keywords: ['bleeding','hemorrhage','anticoagulant bleeding'] },
    { slug: 'thrombosis', label: 'Drug-Induced Thrombosis', keywords: ['thrombosis','VTE-thrombosis','hypercoagulable'] },
    { slug: 'anaphylaxis', label: 'Anaphylaxis / Hypersensitivity', keywords: ['anaphylaxis','hypersensitivity','allergic reaction'] },
    { slug: 'sjs-ten', label: 'Stevens-Johnson Syndrome / TEN', keywords: ['Stevens-Johnson','SJS','TEN','toxic epidermal'] },
    { slug: 'dress', label: 'DRESS Syndrome', keywords: ['DRESS','drug reaction with eosinophilia'] },
    { slug: 'infusion-reactions', label: 'Biologic Infusion Reactions', keywords: ['infusion reaction','infusion-related'] },
    { slug: 'extrapyramidal', label: 'Extrapyramidal Effects', keywords: ['extrapyramidal','EPS','akathisia','tardive','dystonia'] },
    { slug: 'weight-gain', label: 'Drug-Induced Weight Gain', keywords: ['weight gain','drug-induced weight'] },
    { slug: 'hyperlipidemia', label: 'Drug-Induced Hyperlipidemia', keywords: ['drug-induced-hyperlipidemia','cholesterol elevation'] },
    { slug: 'drug-induced-lupus', label: 'Drug-Induced Lupus', keywords: ['drug-induced lupus','DILE','lupus-like'] },
  ];
  return clusters.map(c => {
    const kw = c.keywords.map(k => k.toLowerCase());
    const matched = drugs.filter(d => {
      const text = [
        ...(d.adverse_effect_tags || []),
        ...(d.schema_memberships?.adverse_cluster || []),
        ...(d.adverse_effects?.serious || []),
        ...(d.adverse_effects?.common || []),
        ...(d.black_box_warnings || []),
      ].join(' ').toLowerCase();
      return kw.some(k => text.includes(k));
    });
    return {
      params: { cluster: c.slug },
      props: { label: c.label, drugs: matched, slug: c.slug },
    };
  });
}

const { label, drugs, slug } = Astro.props as { label: string; drugs: any[]; slug: string };
const base = import.meta.env.BASE_URL;
const prose = proseMap[slug] || null;
---
<SchemaLayout title={`${label} — Adverse Effects`} schema="adverse-effects" description={`Drugs associated with ${label}: mechanisms, risk factors, monitoring, and nursing management`}>

  <div class="mb-2">
    <a href={`${base}schemas/08-adverse-effects/`} class="text-sm text-base-content/60 hover:text-primary">← Schema 8: Adverse Effects</a>
  </div>

  <div class="mb-8">
    <h1 class="text-4xl font-serif font-bold text-base-content mb-2">{label}</h1>
    <p class="text-base-content/60">{drugs.length} drug{drugs.length !== 1 ? 's' : ''} in this reference are associated with this adverse effect.</p>
  </div>

  {prose ? (
    <div class="prose max-w-none mb-10">
      <h2 class="text-2xl font-serif font-bold mb-3">Mechanism of the Adverse Effect</h2>
      <p>{prose.p1}</p>
      <h2 class="text-2xl font-serif font-bold mb-3 mt-6">Risk Factors & Predisposing Conditions</h2>
      <p>{prose.p2}</p>
      <h2 class="text-2xl font-serif font-bold mb-3 mt-6">Recognition & Monitoring</h2>
      <p>{prose.p3}</p>
      <h2 class="text-2xl font-serif font-bold mb-3 mt-6">Nursing Interventions</h2>
      <p>{prose.p4}</p>
      <h2 class="text-2xl font-serif font-bold mb-3 mt-6">Patient Education</h2>
      <p>{prose.p5}</p>
    </div>
  ) : (
    <div class="prose max-w-none mb-8">
      <p>The adverse effect of <strong>{label}</strong> involves {drugs.length} drugs in this reference that share this toxicity concern. Understanding the mechanism, risk factors, and monitoring approach is essential for safe pharmacological management. The drugs listed below should be reviewed individually for specific onset timing, incidence rates, severity grading, and clinical management recommendations. Consult current prescribing information and institutional protocols for drug-specific monitoring parameters and intervention thresholds.</p>
    </div>
  )}

  <div class="mb-10">
    <h2 class="text-2xl font-serif font-bold mb-4">Implicated Drugs ({drugs.length})</h2>
    {drugs.length === 0 ? (
      <div class="alert alert-info"><span>No drugs specifically tagged for this adverse effect cluster. See individual drug profiles for adverse effect details.</span></div>
    ) : (
      <div class="overflow-x-auto">
        <table class="table table-zebra w-full">
          <thead>
            <tr>
              <th>Drug</th>
              <th>Class</th>
              <th>Severity</th>
              <th>Safety Flags</th>
            </tr>
          </thead>
          <tbody>
            {drugs.map((d: any) => {
              const serious = (d.adverse_effects?.serious || []) as string[];
              const bbw = (d.black_box_warnings || []) as string[];
              const isSevere = bbw.length > 0 || serious.length > 0;
              return (
                <tr class={d.ismp_high_alert || bbw.length > 0 ? 'border-l-4 border-error' : ''}>
                  <td>
                    <a href={`${base}drugs/${d.id}/`} class="font-semibold text-primary hover:underline">{d.generic_name}</a>
                  </td>
                  <td class="text-sm">{d.drug_class}</td>
                  <td>
                    {bbw.length > 0
                      ? <span class="badge badge-error badge-sm">BBW</span>
                      : isSevere
                        ? <span class="badge badge-warning badge-sm">Serious</span>
                        : <span class="badge badge-ghost badge-sm">Moderate</span>
                    }
                  </td>
                  <td class="flex gap-1 flex-wrap">
                    {d.ismp_high_alert && <span class="badge badge-error badge-sm">HIGH ALERT</span>}
                    {d.beers_criteria && <span class="badge badge-warning badge-sm">BEERS</span>}
                    {d.tdm_required && <span class="badge badge-info badge-sm">TDM</span>}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <div class="alert alert-warning mb-6">
    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
    <div>
      <p class="font-semibold">Pharmacovigilance note</p>
      <p class="text-sm">Adverse drug event incidence varies substantially by dose, patient population, and comorbidities. Always consult current prescribing information. Report adverse drug events to FDA MedWatch.</p>
    </div>
  </div>

  <div class="alert alert-info">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
    <div>
      <p class="font-semibold">Cross-schema navigation</p>
      <p class="text-sm">
        See <a href={`${base}schemas/08-adverse-effects/black-box-warnings/`} class="link">Black Box Warnings compilation</a> •
        <a href={`${base}schemas/08-adverse-effects/beers-criteria/`} class="link">Beers Criteria</a> •
        <a href={`${base}schemas/09-drug-interactions/`} class="link">Drug Interactions (Schema 9)</a>
      </p>
    </div>
  </div>

</SchemaLayout>
