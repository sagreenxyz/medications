const targetMap: Record<string, TargetInfo> = {
  'gpcr-adrenergic': {
    label: "Adrenergic Receptors (α/β GPCRs)",
    physiology: `Adrenergic receptors are G-protein-coupled receptors (GPCRs) activated by endogenous catecholamines—epinephrine and norepinephrine—released from sympathetic nerve terminals and the adrenal medulla. α1-receptors couple to Gq, activating phospholipase C and elevating intracellular calcium to produce vasoconstriction and mydriasis. α2-receptors couple to Gi, inhibiting adenylyl cyclase and reducing cAMP, thereby suppressing presynaptic norepinephrine release and lowering central sympathetic tone. β1-receptors couple to Gs, increasing cAMP and activating PKA to augment cardiac rate and contractility. β2-receptors on smooth muscle cells similarly raise cAMP but produce bronchodilation and vasodilation, while β3-receptors mediate lipolysis in adipose tissue.`,
    activation: `Activation of β1-receptors increases heart rate (chronotropy), contractility (inotropy), and conduction velocity, elevating cardiac output. β2-receptor activation relaxes bronchial smooth muscle, dilates peripheral vasculature, and promotes glycogenolysis, providing the physiological basis for bronchodilator therapy. α1-receptor stimulation produces smooth-muscle contraction, raising systemic vascular resistance and blood pressure; it also contracts the internal urethral sphincter. Inhibition of these receptors—via selective or non-selective antagonists—lowers heart rate and blood pressure (β-blockade), reduces intraocular pressure (β-blockade in ciliary epithelium), or causes vasodilation and reflex tachycardia (α1-blockade).`,
    disease: `Adrenergic receptor modulation is central to management of hypertension, heart failure, angina, arrhythmias, asthma, COPD, benign prostatic hyperplasia, glaucoma, and pheochromocytoma. β-blockers reduce myocardial oxygen demand and prevent pathological remodeling post-MI, making them first-line in chronic heart failure and post-infarction cardioprotection. α1-blockers relax bladder neck smooth muscle, alleviating obstructive urinary symptoms. The target is also exploited in anesthesia (α2-agonists for sedation), septic shock resuscitation (vasopressors), and ADHD (α2-agonists reducing prefrontal cortical noise).`,
    structure: `Adrenergic receptors possess seven transmembrane α-helical domains with an orthosteric binding pocket formed by transmembrane helices 3, 5, 6, and 7. The catecholamine pharmacophore—a catechol ring with a β-hydroxyl ethylamine side chain—makes critical contacts with Asp113 (TM3) and Ser204/207 (TM5). Selectivity between subtypes arises from subtle differences in binding pocket geometry; β1-selective antagonists such as metoprolol exploit an alanine vs. serine difference at position 7.39 compared to β2. Agonists stabilize an active receptor conformation that promotes G-protein coupling, while inverse agonists suppress basal receptor activity below constitutive levels.`,
    toxicology: `Excessive β-adrenergic stimulation produces tachycardia, hypertension, myocardial ischemia, and hypokalemia through transcellular potassium shift; in overdose, sympathomimetic toxidrome manifests as diaphoresis, mydriasis, hyperthermia, and agitation. Conversely, β-blocker overdose causes bradycardia, hypotension, heart block, bronchospasm, and hypoglycemia masked by blunted adrenergic counter-regulation. α1-blocker toxicity produces orthostatic hypotension and reflex tachycardia. Non-selective β-blockade in asthma or COPD can precipitate life-threatening bronchospasm by blocking β2-mediated bronchodilation.`,
    familyMatch: ['adrenergic-receptor-agonism','alpha-adrenergic','beta-adrenergic','non-selective-beta-blockade','beta1-selective-blockade','alpha1-blockade','alpha2-agonism'],
    targetMatch: /adren|alpha.recep|beta.recep|catecholamine recep/i,
    classMatch: ['adrenergic'],
  },
  'gpcr-cholinergic': {
    label: "Cholinergic Receptors (Muscarinic/Nicotinic)",
    physiology: `Cholinergic receptors transduce acetylcholine signaling at parasympathetic effector organs (muscarinic, M1-M5), skeletal neuromuscular junctions (nicotinic NMJ), and autonomic ganglia (nicotinic ganglionic). M1 and M3 receptors couple to Gq, activating phospholipase C; M2 receptors couple to Gi, slowing AV nodal conduction and reducing heart rate; M4 and M5 modulate dopaminergic pathways in the CNS. Nicotinic receptors are ligand-gated ion channels permeable to Na+ and K+, rapidly depolarizing postsynaptic membranes within milliseconds. Acetylcholinesterase (AChE) terminates synaptic signaling by hydrolyzing ACh to choline and acetate in the synaptic cleft.`,
    activation: `Muscarinic activation produces the classic SLUD/SLUDGE response—salivation, lacrimation, urination, defecation, GI hypermotility, and emesis—as well as bronchoconstriction, bradycardia, and miosis. M1-selective activation enhances cognitive function and memory consolidation by augmenting hippocampal theta rhythms. Nicotinic NMJ receptor activation triggers end-plate potentials leading to muscle contraction; ganglionic nicotinic stimulation increases both sympathetic and parasympathetic outflow. Inhibition of muscarinic receptors (anticholinergics) produces dry mouth, urinary retention, constipation, tachycardia, bronchodilation, and mydriasis—effects with therapeutic applications in COPD, overactive bladder, Parkinson disease, and motion sickness.`,
    disease: `AChE inhibitors are first-line for Alzheimer dementia (central M1 and nicotinic facilitation) and myasthenia gravis (peripheral NMJ augmentation). Muscarinic antagonists treat COPD and asthma (ipratropium, tiotropium), overactive bladder (oxybutynin, solifenacin), Parkinson disease tremor, and motion sickness. Organophosphate poisoning causes a life-threatening cholinergic crisis requiring atropine and pralidoxime. Neuromuscular blocking agents acting at nicotinic NMJ receptors are indispensable in anesthesia and intensive care.`,
    structure: `Muscarinic receptors share the GPCR seven-transmembrane topology with a conserved orthosteric binding site deep within the transmembrane bundle. Acetylcholine binds through a quaternary nitrogen-Asp105 salt bridge and cation-pi interactions with aromatic residues in TM5 and TM6. Allosteric sites on the extracellular vestibule allow bitopic ligand design for subtype selectivity. Nicotinic receptors are pentameric Cys-loop ligand-gated ion channels; two ACh molecules must bind at alpha-delta and alpha-gamma subunit interfaces to open the central Na+/K+-permeable pore.`,
    toxicology: `Cholinergic toxidrome from AChE inhibitor poisoning (organophosphates, carbamates) produces SLUDGE plus the "killer Bs"—bradycardia, bronchospasm, and bronchorrhea—and is fatal without rapid atropine titration. Chronic AChE inhibitor use at therapeutic doses causes nausea, vomiting, and diarrhea in 10-20% of patients. Anticholinergic toxidrome (hot as a hare, dry as a bone, red as a beet, blind as a bat, mad as a hatter) results from excessive muscarinic blockade; physostigmine reverses CNS manifestations. Depolarizing neuromuscular blockers like succinylcholine cause transient fasciculations and dangerous hyperkalemia in burns, crush injury, or denervation.`,
    familyMatch: ['muscarinic-antagonism','muscarinic-agonism','AChE-inhibition','nicotinic-agonism','nicotinic-antagonism','muscarinic-antagonism-bronchodilation'],
    targetMatch: /muscarin|cholinerg|acetylcholin|nicotinic|AChE/i,
    classMatch: ['cholinergic'],
  },
  'gpcr-opioid': {
    label: "Opioid Receptors (mu/kappa/delta GPCRs)",
    physiology: `Opioid receptors (mu/MOR, kappa/KOR, delta/DOR, and nociceptin ORL1) are Gi/o-coupled GPCRs distributed throughout the CNS, peripheral sensory neurons, and enteric nervous system. Endogenous ligands—beta-endorphin (mu), dynorphin (kappa), enkephalins (delta)—are released from neurons and immune cells as modulators of pain, stress, reward, and autonomic function. Receptor activation inhibits adenylyl cyclase (reducing cAMP), opens inwardly rectifying K+ channels (hyperpolarization), and closes voltage-gated Ca2+ channels, collectively suppressing neuronal excitability and neurotransmitter release. mu-receptor activation in the ventral tegmental area releases dopamine in the nucleus accumbens, underpinning both analgesia and addictive potential.`,
    activation: `mu-opioid receptor activation produces potent analgesia, euphoria, sedation, respiratory depression, miosis, decreased GI motility (constipation), and antitussive effects. kappa-receptor activation provides analgesia and sedation but also causes dysphoria and psychotomimetic effects, limiting clinical utility. Antagonism of opioid receptors reverses respiratory depression and sedation (naloxone) and is used to treat opioid use disorder (naltrexone). Partial agonists at the mu-receptor (buprenorphine) produce analgesia with a ceiling effect on respiratory depression, improving safety margin for addiction treatment.`,
    disease: `Opioids are the mainstay of moderate-to-severe acute pain management, cancer pain, and palliative care. mu-agonists reduce dyspnea in end-stage heart failure and COPD. Antidiarrheal agents (loperamide, diphenoxylate) act peripherally at intestinal opioid receptors. Opioid use disorder is treated with methadone maintenance, buprenorphine-naloxone (Suboxone), or naltrexone. The opioid epidemic has driven development of abuse-deterrent formulations, peripherally restricted antagonists (methylnaltrexone for opioid-induced constipation), and non-opioid analgesic adjuncts.`,
    structure: `Opioid receptors adopt the canonical class A GPCR fold; the orthosteric binding site is formed by a solvent-exposed pocket at the extracellular surface of the transmembrane bundle. The conserved "message-address" pharmacophore concept explains selectivity: the tyramine "message" domain engages Asp147 (TM3) across all subtypes, while the "address" domain differentiates receptor subtypes through contacts with divergent extracellular loop 2 residues. Biased agonism—ligands that preferentially activate G-protein over beta-arrestin pathways—is under investigation to separate analgesia from respiratory depression and constipation.`,
    toxicology: `Opioid overdose produces the classic toxidrome triad: miosis (pinpoint pupils), respiratory depression, and decreased consciousness. Respiratory depression results from mu-receptor activation in the pre-Botzinger complex of the medulla, reducing respiratory rate and tidal volume; death occurs from apnea. Naloxone competitively reverses all opioid effects within minutes but has a shorter half-life than most opioids, necessitating repeat dosing or infusion. Chronic opioid use causes physical dependence; abrupt cessation precipitates an autonomic withdrawal syndrome with tachycardia, hypertension, diaphoresis, and piloerection mediated by rebound locus coeruleus noradrenergic firing.`,
    familyMatch: ['mu-opioid-agonism','mu-opioid-antagonism','mu-opioid-partial-agonism','opioid-receptor-agonism','kappa-opioid'],
    targetMatch: /opioid|mu.recep|kappa.recep|delta.recep|MOR|KOR/i,
    classMatch: [],
  },
  'gpcr-histamine': {
    label: "Histamine Receptors (H1/H2 GPCRs)",
    physiology: `Histamine is synthesized from histidine by histidine decarboxylase in mast cells, basophils, enterochromaffin-like (ECL) cells of the gastric mucosa, and histaminergic neurons of the tuberomammillary nucleus in the posterior hypothalamus. H1 receptors couple to Gq, activating phospholipase C and raising intracellular calcium; they are expressed on vascular endothelium, smooth muscle, and CNS neurons. H2 receptors couple to Gs, increasing cAMP and activating proton pump secretion in gastric parietal cells, as well as augmenting cardiac contractility and heart rate. H3 receptors function as presynaptic autoreceptors limiting histamine release, and H4 receptors mediate immune cell chemotaxis.`,
    activation: `H1 activation produces vasodilation, increased vascular permeability (wheal-and-flare), bronchoconstriction, pruritus, and CNS arousal/wakefulness. H2 activation in parietal cells stimulates acid secretion via increased cAMP and PKA-dependent phosphorylation of the H+/K+-ATPase. H1 antagonism (antihistamines) relieves allergic rhinitis, urticaria, and pruritus; first-generation agents cross the blood-brain barrier to cause sedation (used in insomnia), while second-generation agents are peripherally selective. H2 antagonism reduces gastric acid secretion, healing peptic ulcers and treating GERD, though proton pump inhibitors have largely supplanted H2 blockers for most indications.`,
    disease: `H1-antihistamines treat seasonal allergic rhinitis, urticaria, anaphylaxis (adjunct to epinephrine), motion sickness (vestibular H1), and insomnia. H2-antagonists treat peptic ulcer disease, GERD, and stress ulcer prophylaxis in critically ill patients. Histamine is also involved in anaphylaxis, mastocytosis, and carcinoid syndrome. Second-generation H1 antagonists (cetirizine, loratadine, fexofenadine) have largely replaced first-generation agents for allergy because of the improved CNS safety profile and lack of impaired driving performance.`,
    structure: `H1 and H2 receptors are class A GPCRs with seven transmembrane helices. The H1 receptor orthosteric site features a key Asp107 residue (TM3) that forms a salt bridge with the protonated amine of ligands, along with aromatic contacts in TM4 and TM6. First-generation antihistamines (diphenhydramine, promethazine) are highly lipophilic with a small topological polar surface area, enabling CNS penetration; second-generation agents (fexofenadine) have larger polar surface areas and efflux transporter recognition that restricts brain entry. The H2 receptor employs a distinct binding geometry that allows cimetidine and ranitidine selectivity.`,
    toxicology: `First-generation H1 antihistamines cause anticholinergic toxidrome in overdose—urinary retention, dry mouth, tachycardia, delirium—and QT prolongation at high doses. Paradoxical CNS excitation and seizures can occur in children. Terfenadine and astemizole (withdrawn) caused fatal torsades de pointes through hERG channel blockade; this liability shaped all subsequent antihistamine development. H2 blocker toxicity is rare at therapeutic doses; cimetidine notably inhibits CYP1A2, 2C9, and 3A4, producing numerous drug interactions (warfarin, phenytoin, theophylline). Intravenous promethazine carries an FDA black box warning for severe tissue necrosis with extravasation.`,
    familyMatch: ['H1-antagonism','H1-antihistamine','H2-antagonism'],
    targetMatch: /histamine|H1.recep|H2.recep/i,
    classMatch: [],
  },
  'gpcr-angiotensin': {
    label: "Angiotensin AT1 Receptors",
    physiology: `The renin-angiotensin-aldosterone system (RAAS) is the principal hormonal axis regulating blood pressure, sodium balance, and vascular tone. Renin (released from juxtaglomerular cells in response to reduced renal perfusion, sympathetic activation, or low tubular sodium) cleaves angiotensinogen to angiotensin I; ACE converts angiotensin I to angiotensin II. AT1 receptors couple to Gq and G12/13, activating PKC-mediated vasoconstriction, aldosterone secretion (adrenal cortex), sodium reabsorption (proximal tubule), and myocardial/vascular fibrosis. AT2 receptors oppose AT1 signaling, promoting vasodilation and natriuresis.`,
    activation: `AT1 receptor activation produces potent arteriolar vasoconstriction (Gq/IP3/calcium), aldosterone release (promoting Na+/K+ exchange in the collecting duct), vasopressin secretion, and cardiac and vascular remodeling through pro-fibrotic and pro-hypertrophic signaling via ERK, JNK, and TGF-beta pathways. AT1 blockade (ARBs) and upstream ACE inhibition lower blood pressure, reduce proteinuria by dilating the efferent arteriole, attenuate adverse cardiac remodeling in heart failure, and slow CKD progression in diabetic nephropathy. Aldosterone antagonism (spironolactone, eplerenone) further reduces the downstream sequelae of RAAS activation.`,
    disease: `ARBs and ACE inhibitors are first-line therapies for hypertension, chronic heart failure (HFrEF), post-MI cardioprotection, and diabetic nephropathy. Combined neprilysin-AT1 inhibition (sacubitril-valsartan) augments natriuretic peptides while blocking angiotensin II, producing superior outcomes versus ACE inhibition alone in HFrEF. RAAS blockade reduces the rate of decline in GFR in CKD. Direct renin inhibitors (aliskiren) block RAAS at the initiating step but have limited clinical adoption due to lack of outcomes benefit over existing agents.`,
    structure: `The AT1 receptor is a class A GPCR; angiotensin II engages the receptor primarily through its C-terminal phenylalanine residue contacting the extracellular binding groove and the N-terminal Asp1-Arg2 dipeptide binding deep within the transmembrane bundle. ARBs are biaryl tetrazole or carboxylate compounds that occupy the same orthosteric pocket, with additional contacts to extracellular loops providing subtype selectivity and insurmountable (candesartan, irbesartan) versus surmountable (losartan, valsartan) antagonism profiles. The non-peptide scaffold of ARBs confers oral bioavailability unlike angiotensin II analogues.`,
    toxicology: `RAAS blockade can precipitate acute kidney injury in bilateral renal artery stenosis or severe volume depletion by abolishing the efferent arteriolar tone that maintains glomerular filtration. Hyperkalemia is a class effect, most dangerous in patients with CKD or those co-prescribed potassium-sparing diuretics. ACE inhibitors cause bradykinin-mediated angioedema (life-threatening when laryngeal) in approximately 0.1-0.5% of patients; ARBs carry a lower but non-zero cross-reactivity risk. Both drug classes are absolutely contraindicated in pregnancy due to fetotoxicity affecting renal development.`,
    familyMatch: ['AT1-blockade','ACE-inhibition','RAAS-blockade','neprilysin-inhibition'],
    targetMatch: /angiotensin|AT1|RAAS|renin.angiotensin/i,
    classMatch: [],
  },
  'gpcr-glp1': {
    label: "GLP-1 Receptors (Incretin GPCRs)",
    physiology: `Glucagon-like peptide-1 (GLP-1) is an incretin hormone secreted by L-cells of the distal ileum and colon in response to nutrient ingestion. The GLP-1 receptor is a class B (secretin-family) GPCR that couples primarily to Gs, activating adenylyl cyclase and raising cAMP in pancreatic beta-cells to potentiate glucose-stimulated insulin secretion. Native GLP-1 is rapidly degraded by dipeptidyl peptidase-4 (DPP-4), limiting its plasma half-life to 1-2 minutes; pharmacological GLP-1 receptor agonists are engineered to resist DPP-4 cleavage. GLP-1 receptors are also expressed in the hypothalamus, vagal afferents, stomach, heart, and kidney.`,
    activation: `GLP-1 receptor activation in pancreatic beta-cells potentiates insulin secretion only in the presence of elevated glucose (glucose-dependent mechanism), markedly reducing hypoglycemia risk relative to sulfonylureas. Activation also suppresses glucagon secretion from alpha-cells, slows gastric emptying (reducing postprandial glucose excursions), and acts centrally on the hypothalamic arcuate nucleus to reduce appetite and food intake. Renal GLP-1 receptor activation promotes natriuresis. Long-acting GLP-1 receptor agonists additionally reduce major adverse cardiovascular events and slow progression of diabetic kidney disease through mechanisms that extend beyond glycemic control.`,
    disease: `GLP-1 receptor agonists are now first-or second-line pharmacotherapy for type 2 diabetes, particularly in patients with established cardiovascular disease, heart failure, or CKD. Semaglutide (oral and injectable) and tirzepatide (dual GIP/GLP-1 agonist) produce 10-20% body weight reduction and are FDA-approved for chronic weight management. DPP-4 inhibitors (gliptins) prolong endogenous GLP-1 activity with modest glucose lowering and a neutral cardiovascular profile. Emerging GLP-1-based combinations target NASH, polycystic ovary syndrome, and chronic obesity management.`,
    structure: `The class B GLP-1 receptor has a large extracellular domain (ECD) that serves as the primary binding platform for the C-terminus of GLP-1; the N-terminus of GLP-1 then inserts into the transmembrane bundle to stabilize an active conformation. GLP-1 receptor agonist peptides (exenatide, liraglutide, semaglutide) share a GLP-1-like alpha-helical structure; fatty acid conjugation (liraglutide C16, semaglutide C18 diacid) enables albumin binding, prolonging half-life to 13 hours and 7 days, respectively. Tirzepatide is a dual acylated peptide that activates both GLP-1R and GIPR, producing synergistic glucose-lowering and weight loss.`,
    toxicology: `GLP-1 receptor agonists cause nausea, vomiting, and diarrhea in 20-40% of patients, predominantly during dose escalation; these effects are dose-dependent and typically transient. Rare cases of acute pancreatitis have been reported; the causal relationship remains debated but warrants cessation if pancreatitis occurs. Thyroid C-cell tumors observed in rodents (medullary thyroid carcinoma) led to a boxed warning and contraindication in patients with personal or family history of MTC or MEN2, though the human risk is not established. Rapid weight loss can precipitate gallstone formation and cholecystitis in susceptible patients.`,
    familyMatch: ['GLP-1-receptor-agonism','GLP-1-GIP-receptor-agonism','DPP-4-inhibition','incretin'],
    targetMatch: /GLP-1|GLP1|incretin|DPP-4|glucagon.like/i,
    classMatch: [],
  },
  'gpcr-dopamine': {
    label: "Dopamine Receptors (D1-D5 GPCRs)",
    physiology: `Dopamine exerts its effects through five GPCR subtypes (D1-D5) grouped into D1-like (D1, D5; Gs-coupled, stimulate adenylyl cyclase) and D2-like (D2, D3, D4; Gi-coupled, inhibit adenylyl cyclase) families. The nigrostriatal pathway (substantia nigra to striatum) coordinates motor control; dopaminergic degeneration here produces Parkinson disease. The mesolimbic pathway (VTA to nucleus accumbens) mediates reward, motivation, and reinforcement; it is the substrate for addiction. The mesocortical pathway (VTA to prefrontal cortex) regulates executive function and working memory. The tuberoinfundibular pathway (hypothalamus to pituitary) inhibits prolactin secretion via D2 receptors on lactotrophs.`,
    activation: `D1/D5 activation increases cAMP, potentiating PKA-dependent signaling that facilitates striatal motor output and cortical cognitive processing. D2 receptor activation inhibits adenylyl cyclase, reducing cAMP in the striatum (indirect pathway suppression), pituitary (prolactin inhibition), and gut (antiemesis via CTZ). D2 antagonism is the shared mechanism of all first-generation antipsychotics and antiemetics; it produces therapeutic antipsychotic effects but also extrapyramidal side effects (EPS) and hyperprolactinemia. Dopamine agonists (pramipexole, ropinirole, levodopa) restore dopaminergic tone in Parkinson disease.`,
    disease: `Dopamine receptor modulation is central to schizophrenia, Parkinson disease, bipolar disorder, major depression (augmentation), ADHD, nausea/vomiting, restless leg syndrome, prolactinoma, and reward-associated disorders. Antipsychotics (D2 antagonists) treat positive symptoms of schizophrenia; second-generation antipsychotics add 5-HT2A antagonism to improve negative symptom profile and reduce EPS. Cabergoline and bromocriptine (D2 agonists) suppress prolactin and shrink prolactinomas. Metoclopramide and domperidone are prokinetic antiemetics that block D2 receptors in the CTZ and gastric fundus.`,
    structure: `D2-like receptors share the class A GPCR architecture; D2 and D3 have highest structural similarity and share binding of most antipsychotics. The orthosteric binding site is formed by an Asp114 (TM3) salt bridge with the protonated amine, capped by hydrophobic contacts in TM4 and TM6. D2 receptors exist as long (D2L, predominant postsynaptic) and short (D2S, presynaptic autoreceptor) isoforms through alternative splicing in the third intracellular loop—an important pharmacological distinction. Partial D2 agonists (aripiprazole, brexpiprazole, cariprazine) stabilize a conformation between full agonism and full antagonism, acting as functional antagonists in hyperdopaminergic states and agonists in hypodopaminergic contexts.`,
    toxicology: `D2 receptor hyperblockade produces extrapyramidal syndromes—acute dystonia, akathisia, parkinsonism, and tardive dyskinesia (late-onset, potentially irreversible dyskinesia from D2 receptor upregulation). Dopaminergic agonist toxicity includes impulse control disorders (pathological gambling, hypersexuality) from mesolimbic D3/D2 overstimulation, especially with non-ergot agonists. Dopamine agonist withdrawal syndrome resembles adrenal insufficiency with severe dysautonomia. Neuroleptic malignant syndrome (NMS)—hyperthermia, rigidity, altered consciousness, autonomic instability—is a rare but potentially fatal complication of abrupt D2 blockade or sudden cessation of dopaminergic therapy.`,
    familyMatch: ['D2-antagonism','D2-agonism','D2-partial-agonism','D2-5HT2A-antagonism','D3-agonism','D3-partial-agonism','dopamine-agonism'],
    targetMatch: /dopamine recep|D1.recep|D2.recep|D3.recep|nigrostriatal|dopaminergic/i,
    classMatch: [],
  },
  'gpcr-serotonin': {
    label: "Serotonin Receptors (5-HT GPCRs)",
    physiology: `Serotonin (5-hydroxytryptamine) signals through 14 receptor subtypes; all except 5-HT3 are GPCRs. 5-HT1A and 5-HT1B/D are Gi-coupled autoreceptors that limit serotonergic neurotransmission; 5-HT2A, 5-HT2B, and 5-HT2C couple to Gq; 5-HT4, 5-HT6, and 5-HT7 couple to Gs. The dorsal raphe nucleus is the primary source of CNS serotonin, projecting broadly to the limbic system and cortex to modulate mood, cognition, sleep, and appetite. Peripheral serotonin (more than 90% of body stores) resides in enterochromaffin cells, regulating gut motility; 5-HT3 in vagal afferents mediates nausea reflexes.`,
    activation: `5-HT1A autoreceptor activation at the raphe soma inhibits serotonergic firing; postsynaptic 5-HT1A activation in the hippocampus and prefrontal cortex produces anxiolytic effects exploited by buspirone. 5-HT2A blockade in the cortex is central to the atypical antipsychotic mechanism and reduces EPS from D2 blockade. 5-HT3 antagonism (ondansetron) blocks vagal and CTZ-mediated emesis. 5-HT4 agonism in the gut accelerates motility (prokinetic). Triptans (sumatriptan) act as 5-HT1B/1D agonists to constrict meningeal blood vessels and inhibit trigeminal nociceptive transmission, aborting migraine attacks.`,
    disease: `Serotonin modulation treats major depression (SSRIs, SNRIs—block SERT reuptake transporter to increase synaptic 5-HT), anxiety disorders, OCD, panic disorder, PTSD, migraine, CINV, IBS, Parkinson disease psychosis (pimavanserin, selective 5-HT2A inverse agonist), and schizophrenia. 5-HT2B agonism causes valvular heart disease (fenfluramine, withdrawn) and pulmonary arterial hypertension (ergotamine). 5-HT modulators also treat premature ejaculation, fibromyalgia, and chronic neuropathic pain (SNRIs).`,
    structure: `5-HT receptors with GPCR architecture share conserved residues for serotonin binding—Asp116 (TM3) and Ser212 (TM5)—plus aromatic contacts forming a hydrophobic cage around the indole ring. SSRI binding to SERT (not a receptor but a transporter) involves two sites in the outward-open conformation of the LeuT-fold protein, blocking the serotonin translocation cycle. 5-HT1B/1D receptors are highly expressed in trigeminal vasculature; triptans achieve selectivity through lipophilic contacts in TM3/7 that differ from 5-HT2 receptors, explaining their vasoconstrictor specificity.`,
    toxicology: `Serotonin syndrome arises from excessive serotonergic signaling, characteristically from drug combinations (SSRI + MAOI, SSRI + tramadol, linezolid, or methylene blue). The clinical triad of mental status changes, autonomic instability, and neuromuscular abnormalities (clonus, hyperreflexia, tremor) distinguishes it from NMS; management requires drug cessation, cyproheptadine (5-HT2A antagonist), and supportive care. SSRI discontinuation syndrome (dizziness, paresthesias, flu-like symptoms, electric-shock sensations) occurs with abrupt cessation, particularly of short-half-life agents like paroxetine. QT prolongation is a class liability of some serotonergic agents (citalopram, escitalopram at high doses) through hERG channel blockade.`,
    familyMatch: ['5-HT-antagonism','5-HT-modulation','5-HT1A-partial-agonism','5-HT1B-agonism','5-HT1D-agonism','5-HT1F-agonism','5-HT2A-antagonism','5-HT3-antagonism','5-HT4-receptor-agonism','5HT1B-1D-agonism'],
    targetMatch: /serotonin recep|5-HT recep|5HT recep|triptamine|5-hydroxy/i,
    classMatch: [],
  },
  'ligand-gated-channels': {
    label: "Ligand-Gated Ion Channels (GABA-A, NMDA, nAChR)",
    physiology: `Ligand-gated ion channels (LGICs) couple neurotransmitter binding directly to ion conductance without intervening second-messenger cascades, enabling synaptic transmission on a millisecond timescale. GABA-A receptors are pentameric Cl-permeable channels that mediate fast inhibitory neurotransmission throughout the CNS; benzodiazepines and barbiturates are positive allosteric modulators at distinct sites. NMDA receptors (NR1/NR2 heteromers) are glutamate- and glycine-gated Na+/Ca2+-permeable channels with a voltage-dependent Mg2+ block; they are critical for synaptic plasticity and long-term potentiation. Nicotinic acetylcholine receptors at the NMJ are alpha1-beta1-gamma-delta pentamers mediating skeletal muscle contraction.`,
    activation: `GABA-A receptor activation (chloride influx) hyperpolarizes neurons, providing inhibitory tone; benzodiazepine binding to the alpha/gamma interface increases Cl channel opening frequency without altering conductance or maximal GABA response—accounting for the ceiling effect on CNS depression. Barbiturates at higher concentrations can open GABA-A channels directly in the absence of GABA, explaining the narrower therapeutic index versus benzodiazepines. NMDA receptor blockade (ketamine, memantine) prevents glutamate-mediated excitotoxicity; sub-anesthetic NMDA blockade produces dissociative anesthesia and rapidly acting antidepressant effects. NMJ nicotinic blockade (rocuronium, vecuronium) causes flaccid paralysis for surgical access.`,
    disease: `GABA-A modulators treat anxiety, insomnia, epilepsy (benzodiazepines, barbiturates), and alcohol withdrawal. Zolpidem and related z-drugs are GABA-A modulators selective for alpha1-containing receptors mediating sedation. NMDA antagonists treat moderate-to-severe Alzheimer dementia (memantine), provide dissociative anesthesia (ketamine), and are used in treatment-resistant depression (esketamine intranasal). NMJ blockers are essential for endotracheal intubation and surgical relaxation in anesthesia.`,
    structure: `GABA-A receptors are assembled from five subunits (most commonly 2alpha, 2beta, 1gamma); benzodiazepine binding at the extracellular alpha/gamma interface stabilizes an agonist-bound conformation of increased channel opening frequency. The classic benzodiazepine pharmacophore—a 1,4-benzodiazepine ring system—makes contacts with His101 (alpha1) and Thr206 (gamma2). NMDA receptors require simultaneous glutamate (NR2 subunit) and glycine (NR1 subunit) binding plus membrane depolarization to relieve Mg2+ block; ketamine binds within the open channel pore blocking Na+/Ca2+ conductance.`,
    toxicology: `Benzodiazepine overdose produces CNS and respiratory depression; flumazenil competitively reverses benzodiazepine effects at GABA-A alpha/gamma sites but has a short half-life relative to long-acting benzodiazepines, requiring observation for resedation. Physical dependence and withdrawal seizures (potentially fatal) occur with chronic benzodiazepine use; taper protocols are mandatory. Emergence reactions from ketamine—hallucinations, disorientation—occur in 10-30% of patients; prophylactic benzodiazepines reduce incidence. Succinylcholine-induced hyperkalemia can trigger fatal arrhythmias in patients with denervation injury, burns, or prolonged immobility due to extrajunctional nicotinic receptor upregulation.`,
    familyMatch: ['GABA-A-modulation','GABA-A-positive-modulation','GABA-A-potentiation','GABA-enhancement','nicotinic-antagonism','nicotinic-agonism','NMDA-antagonism'],
    targetMatch: /GABA.A|NMDA|nicotinic|ligand.gated|benzodiazepine recep/i,
    classMatch: [],
  },
  'voltage-gated-sodium': {
    label: "Voltage-Gated Sodium Channels (Nav)",
    physiology: `Voltage-gated sodium channels (Nav1.1-Nav1.9) are the molecular basis of action potential initiation and propagation in excitable cells. Each channel consists of a pore-forming alpha-subunit with four homologous domains (DI-DIV), each containing six transmembrane segments; the S4 segment serves as the voltage sensor. At resting membrane potential, channels exist in a closed resting state; depolarization opens channels (activated), producing the rapid inward Na+ current responsible for the action potential upstroke; rapid inactivation (within milliseconds) terminates conductance. Recovery from inactivation requires repolarization back to the resting membrane potential—providing the basis for use-dependent block by local anesthetics and antiarrhythmics.`,
    activation: `Nav channel blockade inhibits action potential generation and propagation in a use-dependent (state-dependent) fashion—greater effect in frequently firing neurons and depolarized tissues. Class I antiarrhythmics (lidocaine, mexiletine—Ib; flecainide, propafenone—Ic; quinidine, procainamide—Ia) bind to the inactivated or open channel state within the inner pore vestibule to suppress ventricular and atrial ectopy. Local anesthetics (lidocaine, bupivacaine) block Nav in peripheral sensory and motor nerves, producing regional anesthesia without loss of consciousness. Anticonvulsants (phenytoin, carbamazepine, lacosamide) stabilize the inactivated Nav state in rapidly firing hippocampal and cortical neurons.`,
    disease: `Nav channel modulation treats cardiac arrhythmias (Vaughan Williams Class I), epilepsy (partial-onset seizures, generalized tonic-clonic), neuropathic pain (lidocaine patches, carbamazepine in trigeminal neuralgia), and as a component of regional and general anesthesia. Loss-of-function Nav1.1 mutations cause Dravet syndrome, a severe childhood epilepsy; Nav1.7 gain-of-function mutations cause inherited erythromelalgia (extreme burning pain). Inherited Nav1.5 mutations cause long QT syndrome type 3 and Brugada syndrome, informing pharmacogenomic selection of sodium channel blockers.`,
    structure: `The inner pore vestibule of Nav channels has a conserved DEKA selectivity filter (Asp-Glu-Lys-Ala from DI-DIV) that selects Na+ over K+ and Ca2+. Local anesthetics and antiarrhythmics bind within this vestibule by crossing the membrane in neutral form (lipid pathway) or entering the open pore (hydrophilic pathway); key binding residues are F1764 and Y1771 in DIV-S6 of Nav1.5. Lacosamide enhances slow inactivation via a distinct mechanism from classical Nav blockers, providing complementary anticonvulsant activity with a favorable drug interaction profile.`,
    toxicology: `Local anesthetic systemic toxicity (LAST) from inadvertent intravascular injection presents as CNS excitation (seizures) progressing to CNS depression, followed by cardiovascular collapse from cardiac Nav1.5 blockade; treatment is 20% lipid emulsion ("lipid rescue") that extracts lipophilic drug from cardiac tissue. Bupivacaine has greater cardiotoxicity than lidocaine due to slower unbinding kinetics from Nav channels. Flecainide (Ic antiarrhythmic) caused excess mortality in the CAST trial by pro-arrhythmia in post-MI patients; its use is now restricted to structurally normal hearts. Carbamazepine auto-induces CYP3A4 and 2C9, dramatically reducing levels of co-administered drugs.`,
    familyMatch: ['sodium-channel-blockade','sodium-channel-slow-inactivation','sodium channels','voltage-gated sodium channels (inactivated state)'],
    targetMatch: /sodium channel|Nav|Na\+ channel|voltage.gated.Na/i,
    classMatch: ['ion-channel'],
  },
  'voltage-gated-calcium': {
    label: "Voltage-Gated Calcium Channels (Cav)",
    physiology: `Voltage-gated calcium channels (L-, T-, N-, P/Q-, R-types) couple membrane depolarization to intracellular calcium elevation, triggering muscle contraction, neurotransmitter release, cardiac pacemaker activity, and gene expression. L-type channels (Cav1.1-1.4) are the predominant pharmacological target; they are responsible for the plateau phase of the cardiac action potential (Cav1.2), excitation-contraction coupling in vascular and cardiac smooth muscle, and sinoatrial and AV node pacemaker activity. T-type channels (Cav3.1-3.3) generate low-threshold burst firing in thalamic neurons (target in absence epilepsy) and SA node diastolic depolarization. N-type channels at peripheral synaptic terminals mediate nociceptive neurotransmitter release.`,
    activation: `L-type calcium channel blockade (dihydropyridines, phenylalkylamines, benzothiazepines) reduces Ca2+ entry into vascular smooth muscle and cardiac myocytes. Dihydropyridines (amlodipine, nifedipine) exhibit high vascular selectivity, producing peripheral vasodilation and afterload reduction for hypertension; at therapeutic doses they cause reflex tachycardia. Non-dihydropyridines (verapamil, diltiazem) additionally slow AV nodal conduction and reduce cardiac contractility, controlling rate in atrial fibrillation and flutter, and treating angina and hypertrophic cardiomyopathy. N-type channel blockade by ziconotide (intrathecal) treats refractory neuropathic pain.`,
    disease: `Calcium channel blockers treat hypertension, angina pectoris, vasospastic angina (Prinzmetal), rate control in atrial fibrillation/flutter, hypertrophic cardiomyopathy, Raynaud phenomenon, and subarachnoid hemorrhage vasospasm (nimodipine). Ethosuximide and valproate inhibit T-type Cav3 channels in thalamic neurons, treating absence epilepsy. Pregabalin and gabapentin reduce alpha2-delta-subunit trafficking of presynaptic Cav channels in dorsal horn neurons, providing neuropathic pain relief (though their primary mechanism is alpha2-delta-subunit binding, reducing channel surface expression rather than direct pore block).`,
    structure: `The L-type channel alpha1-subunit contains the dihydropyridine binding site at a hydrophobic pocket formed by IIIS5, IIIS6, and IVS6 transmembrane segments; amlodipine makes contacts with Tyr1152 and Met1153. Verapamil binds from the cytoplasmic side of the channel in the open state to the inner pore, while diltiazem occupies an overlapping but distinct site. The dihydropyridine receptor is allosterically linked to ryanodine receptors in the SR of skeletal muscle T-tubules, providing an additional tier of calcium signaling coupling that differs from cardiac L-type channels.`,
    toxicology: `Dihydropyridine overdose causes profound vasodilation, hypotension, and reflex tachycardia; high-dose insulin euglycemia (HIE) therapy improves cardiac output by providing metabolic substrate to calcium-blocked myocardium. Non-dihydropyridine overdose produces severe bradycardia, AV block, and myocardial depression; treatment includes calcium gluconate, glucagon, atropine, and pacing. Verapamil is contraindicated in heart failure with reduced ejection fraction and must not be combined with beta-blockers (risk of complete heart block). Ankle edema from dihydropyridines results from preferential dilation of the precapillary arteriole without proportionate venodilation, increasing capillary hydraulic pressure.`,
    familyMatch: ['calcium-channel-blockade','L-type-calcium-channel','T-type-calcium','calcium-channel'],
    targetMatch: /calcium channel|Cav|Ca2\+ channel|voltage.gated.Ca|dihydropyridine recep/i,
    classMatch: [],
  },
  'voltage-gated-potassium': {
    label: "Potassium Channels (Kv, KATP, hERG)",
    physiology: `Potassium channels are the largest ion channel superfamily, with more than 80 human genes encoding Kv (voltage-gated), Kir (inward rectifier), K2P (two-pore), and KCa (calcium-activated) subtypes. In cardiac myocytes, IKr (hERG/Kv11.1) and IKs (KCNQ1/Kv7.1) mediate repolarization of the action potential; KATP channels in pancreatic beta-cells link cellular energy status to insulin secretion; KCNQ2/3 channels in neurons regulate M-current and firing threshold. The hERG channel is notorious as an off-target for hundreds of structurally diverse drugs, underlying drug-induced QT prolongation and torsades de pointes.`,
    activation: `KATP channel blockade in pancreatic beta-cells (sulfonylureas, meglitinides) depolarizes the beta-cell, opening voltage-gated Ca2+ channels and triggering insulin exocytosis—independent of ambient glucose levels, explaining the risk of hypoglycemia. KATP openers (minoxidil, diazoxide) hyperpolarize vascular smooth muscle and arteriolar endothelium, producing vasodilation used in hypertensive crisis and refractory hypoglycemia. hERG (IKr) channel block prolongs cardiac action potential duration and QT interval; at low concentrations this may be antiarrhythmic (class III), but at toxic concentrations it triggers early afterdepolarizations and torsades de pointes.`,
    disease: `Sulfonylureas and meglitinides treat type 2 diabetes. Class III antiarrhythmics (amiodarone, sotalol, dofetilide, ibutilide) block IKr to prolong cardiac action potential and refractory period, treating atrial fibrillation and ventricular tachycardia. KCNQ2/3 (Kv7) openers treated refractory focal epilepsy. Minoxidil, a KATP opener, is used topically for alopecia and orally for severe hypertension. Diazoxide treats congenital hyperinsulinism. Class III antiarrhythmics require QT monitoring because even modest QT prolongation above the therapeutic target raises torsades de pointes risk.`,
    structure: `Voltage-gated K+ channels are tetrameric, each subunit contributing one S1-S4 voltage-sensing domain and one S5-P-S6 pore domain; the conserved GYGF selectivity filter dehydrates K+ ions for selective conductance. hERG channels possess an unusually large inner vestibule and lack the Pro-Val-Pro motif in S6 that keeps other Kv channels narrow; this unique architecture allows diverse lipophilic, basic drugs (terfenadine, cisapride, sertindole) to bind with high affinity and block the channel. Sulfonylureas bind to the SUR1 regulatory subunit of KATP channels (ABC transporter family), allosterically closing the Kir6.2 pore.`,
    toxicology: `Drug-induced QT prolongation and torsades de pointes from hERG block is the most common cause of drug withdrawal from the market and FDA black box warnings. Risk is amplified by female sex (longer baseline QT), hypokalemia, hypomagnesemia, bradycardia, and concomitant use of multiple QT-prolonging drugs. Sulfonylurea overdose (accidental or intentional) causes prolonged, recurrent hypoglycemia refractory to bolus glucose—octreotide (somatostatin analog) inhibits insulin secretion and is the antidote. Minoxidil causes reflex tachycardia and fluid retention requiring co-prescription of a beta-blocker and loop diuretic.`,
    familyMatch: ['potassium channels (IKr, IKs)','sulfonylurea-KATP-blockade','hERG-block','K-channel'],
    targetMatch: /potassium channel|hERG|KATP|Kv|IKr|IKs|K\+ channel/i,
    classMatch: [],
  },
  'nuclear-receptors': {
    label: "Nuclear Receptors (GR, MR, AR, ER, TR, PPAR)",
    physiology: `Nuclear receptors are ligand-activated transcription factors that directly regulate gene expression by binding to hormone response elements (HREs) in promoter regions of target genes. The superfamily includes steroid receptors (glucocorticoid receptor/GR, mineralocorticoid receptor/MR, androgen receptor/AR, estrogen receptors/ERalpha and ERbeta, progesterone receptor/PR), thyroid hormone receptors (TRalpha and TRbeta), peroxisome proliferator-activated receptors (PPARalpha, PPARgamma, PPARdelta), retinoid receptors (RARalpha-gamma, RXRalpha-gamma), and vitamin D receptor (VDR). Ligand binding induces conformational change in the ligand-binding domain (LBD), releasing heat shock proteins, facilitating DNA binding and coactivator/corepressor recruitment.`,
    activation: `GR activation by corticosteroids produces anti-inflammatory effects through transrepression of NF-kB and AP-1 target genes (reducing cytokine transcription) and transactivation of anti-inflammatory genes (lipocortin-1, MKP-1). MR activation promotes Na+ reabsorption and K+/H+ excretion in the renal collecting duct, raising blood pressure and expanding plasma volume. AR activation drives male secondary sexual development, anabolism, prostate growth, and erythropoiesis; AR antagonism is central to prostate cancer therapy. ERalpha activation supports reproductive biology, bone mineral density, and cardiovascular function; ER modulation forms the basis of breast cancer endocrine therapy.`,
    disease: `Corticosteroids treat inflammatory and autoimmune diseases, adrenal insufficiency, asthma, COPD exacerbations, solid organ transplant rejection, and cerebral edema. MR antagonists (spironolactone, eplerenone, finerenone) reduce cardiovascular mortality in heart failure and CKD. Anti-estrogens and aromatase inhibitors treat estrogen receptor-positive breast cancer. Anti-androgens treat prostate cancer and conditions of androgen excess. PPARgamma agonists (pioglitazone, rosiglitazone) treat type 2 diabetes through insulin sensitization. Thyroid hormone analogs treat hypothyroidism.`,
    structure: `Nuclear receptors share a modular architecture: N-terminal AF-1 activation domain (ligand-independent), central DNA-binding domain (DBD) with two zinc-finger motifs, hinge region, and C-terminal LBD containing the AF-2 activation helix. The LBD hydrophobic ligand-binding pocket accommodates the steroidal or non-steroidal ligand; helix 12 repositions upon agonist binding to create the coactivator interaction surface. SERMs (tamoxifen, raloxifene) position helix 12 differently from full agonists, producing tissue-specific agonist/antagonist mixed profiles by differentially recruiting coactivators vs. corepressors in a tissue-context-dependent manner.`,
    toxicology: `Chronic systemic corticosteroid use produces HPA axis suppression (adrenal insufficiency upon abrupt withdrawal), Cushingoid features (central obesity, buffalo hump, moon facies, striae), osteoporosis, hyperglycemia, hypertension, immunosuppression, cataracts, and growth retardation in children. MR antagonist spironolactone causes gynecomastia and sexual dysfunction through cross-reactivity with AR. PPARgamma agonists cause fluid retention, weight gain, and were associated with increased bladder cancer risk (pioglitazone). Tamoxifen increases endometrial cancer risk (ERalpha agonism in uterus) and venous thromboembolism.`,
    familyMatch: ['glucocorticoid-receptor-agonism','mineralocorticoid-receptor-agonism','androgen-receptor-blockade','estrogen-receptor-modulation','PPAR-agonism','thyroid-receptor-activation','nuclear-receptor'],
    targetMatch: /nuclear recep|glucocorticoid|mineralocorticoid|androgen recep|estrogen recep|PPAR|thyroid recep|steroid recep/i,
    classMatch: ['hormones-analogs'],
  },
  'receptor-tyrosine-kinases': {
    label: "Receptor Tyrosine Kinases (EGFR, HER2, VEGFR, BCR-ABL)",
    physiology: `Receptor tyrosine kinases (RTKs) are single-pass transmembrane proteins with an extracellular ligand-binding domain and an intracellular kinase domain that autophosphorylates tyrosine residues upon ligand-induced dimerization or oligomerization. Key RTK families include the ErbB family (EGFR/HER1, HER2, HER3, HER4), VEGFR family (VEGFR1-3), PDGFR, FLT3, KIT, RET, ALK, and MET. Downstream signaling through RAS-MAPK, PI3K-AKT-mTOR, and STAT pathways controls cell proliferation, survival, differentiation, and angiogenesis. In cancer, gain-of-function mutations, amplification, or chromosomal translocations (e.g., BCR-ABL in CML) drive constitutive RTK activation independent of ligand.`,
    activation: `RTK inhibition with small-molecule tyrosine kinase inhibitors (TKIs) competitively blocks ATP binding at the kinase active site, halting autophosphorylation and downstream oncogenic signaling. EGFR TKIs (erlotinib, gefitinib, osimertinib) treat EGFR-mutant NSCLC; the T790M resistance mutation in EGFR is overcome by third-generation TKI osimertinib. BCR-ABL inhibitors (imatinib, dasatinib, nilotinib) treat CML with high response rates; ponatinib covers the T315I "gatekeeper" mutation. Anti-RTK monoclonal antibodies (trastuzumab/HER2, cetuximab/EGFR, bevacizumab/VEGF ligand) block extracellular domains or circulating growth factors to prevent receptor activation.`,
    disease: `RTK-targeted therapies are FDA-approved for CML (BCR-ABL), NSCLC (EGFR, ALK, ROS1), GIST (KIT, PDGFRA), metastatic breast cancer (HER2), colorectal cancer (EGFR, VEGF), renal cell carcinoma (VEGFR, mTOR), hepatocellular carcinoma (VEGFR), thyroid cancer (RET), and AML (FLT3). Biomarker-driven patient selection (mutation testing, IHC/FISH amplification) is mandatory before initiating most RTK-targeted therapies. Resistance inevitably emerges through secondary kinase domain mutations, alternative pathway activation, or phenotypic transformation.`,
    structure: `RTK kinase domains adopt the bilobal protein kinase fold; the ATP-binding cleft is formed between the N-lobe (beta-sheets) and C-lobe (alpha-helices) with the hinge region connecting them. TKIs are classified as type I (bind active DFG-in conformation, competing with ATP), type II (bind DFG-out inactive conformation—imatinib, sorafenib), or type III (allosteric). The "gatekeeper" residue (T315 in BCR-ABL, T790 in EGFR) at the back of the ATP pocket is the most common site of resistance mutations, which sterically block TKI binding while preserving ATP accommodation due to its more compact binding geometry.`,
    toxicology: `EGFR TKIs cause papulopustular acneiform rash (epidermal EGFR inhibition), diarrhea, and interstitial lung disease. The rash correlates with clinical benefit and is managed with topical antibiotics. BCR-ABL inhibitors cause QT prolongation (dasatinib), fluid retention (imatinib), hepatotoxicity, and cardiovascular events (ponatinib arterial thrombosis). Anti-VEGF therapies (bevacizumab) produce hypertension, wound healing impairment, arterial thromboembolism, and rare bowel perforation. Cardiotoxicity (left ventricular dysfunction) is a class concern with HER2-targeted agents (trastuzumab); baseline and serial echocardiography is required.`,
    familyMatch: ['tyrosine-kinase-inhibitor','EGFR-inhibition','HER2-targeting','VEGFR-inhibition','BCR-ABL-inhibition','FLT3-inhibition','ALK-inhibition','RTK'],
    targetMatch: /tyrosine kinase|EGFR|HER2|VEGFR|BCR.ABL|FLT3|KIT recep|ALK|RTK/i,
    classMatch: [],
  },
  'serine-threonine-kinases': {
    label: "Serine/Threonine Kinases (BRAF, MEK, CDK, mTOR, JAK)",
    physiology: `Serine/threonine kinases (STKs) phosphorylate serine or threonine residues on substrate proteins, propagating intracellular signals for cell cycle progression, survival, differentiation, and immune function. Key oncogenic STKs include BRAF (RAS-MAPK cascade), MEK1/2 (BRAF downstream effector), CDK4/6 (G1/S cell cycle checkpoint), mTORC1/2 (nutrient sensing, translation), PI3K/AKT, and JAK1/2 (JAK-STAT cytokine signaling). BRAFV600E is the most common somatic mutation in melanoma (~50%), substituting glutamic acid for valine and constitutively activating the MAPK pathway independent of RAS. JAK kinases couple cytokine receptors (IL-6R, JAK2/EPO-R, JAK3/common gamma-chain) to STAT transcription factor phosphorylation.`,
    activation: `BRAF inhibitors (vemurafenib, dabrafenib) selectively block BRAFV600E-driven MAPK signaling to suppress melanoma proliferation; paradoxical MAPK activation in BRAF-wild-type cells explains the rare squamoproliferative skin tumors. MEK inhibitors (trametinib, cobimetinib) block the next step in the MAPK cascade and are combined with BRAF inhibitors to prevent resistance. CDK4/6 inhibitors (palbociclib, ribociclib, abemaciclib) arrest tumor cells at the G1/S checkpoint by preventing retinoblastoma protein (Rb) phosphorylation. JAK inhibitors (ruxolitinib, tofacitinib, baricitinib, upadacitinib) reduce inflammatory cytokine signaling in rheumatoid arthritis, myeloproliferative neoplasms, and IBD.`,
    disease: `BRAF/MEK inhibitor combinations treat BRAFV600-mutant melanoma, NSCLC, and thyroid cancer. CDK4/6 inhibitors with endocrine therapy are standard first-line for HR+/HER2-negative metastatic breast cancer. mTOR inhibitors (everolimus, temsirolimus) treat renal cell carcinoma, mantle cell lymphoma, TSC, and PNET; everolimus prevents solid organ transplant rejection. JAK inhibitors treat moderate-to-severe RA (tofacitinib, baricitinib, upadacitinib), myelofibrosis (ruxolitinib), polycythemia vera, and atopic dermatitis. PI3K inhibitors (alpelisib, idelalisib) treat PIK3CA-mutant breast cancer and follicular lymphoma.`,
    structure: `STKs share the bilobal kinase fold with RTKs; selectivity exploits differences in the gatekeeper residue, DFG-loop conformation, and ATP-binding cleft size. BRAF inhibitors achieve BRAFV600E selectivity by exploiting an expanded ATP pocket created by the Val600Glu mutation. CDK4/6 inhibitors occupy a deep hydrophobic cavity adjacent to the hinge region; CDK4 selectivity arises from a His95 (vs. Phe in CDK2) difference in the binding pocket. Allosteric mTOR inhibitors (rapalogs) bind the FKBP12-rapamycin binding (FRB) domain distal to the kinase active site, enabling partial inhibition of mTORC1 with less complete mTORC2 suppression.`,
    toxicology: `CDK4/6 inhibitors cause neutropenia (dose-limiting toxicity) requiring dose interruption and growth factor support; QTc prolongation is a class effect requiring monitoring. BRAF inhibitors cause UV-sensitive squamous cell carcinoma and keratoacanthoma formation in 15-30% of patients within weeks of initiation; dermatology surveillance is mandatory. JAK inhibitors carry boxed warnings for serious infections, malignancies (lymphoma, solid tumors), MACE, thrombosis, and mortality—particularly in patients 50 or older with cardiovascular risk factors. mTOR inhibitors cause non-infectious pneumonitis (5-15%), stomatitis, hyperglycemia, hypertriglyceridemia, and immunosuppression.`,
    familyMatch: ['BRAF-inhibition','MEK-inhibition','CDK4/6-inhibition','mTOR-inhibition','JAK-inhibition','PI3K-inhibition','serine-threonine-kinase'],
    targetMatch: /BRAF|MEK|CDK4|CDK6|mTOR|JAK|PI3K|serine.threonine kinase/i,
    classMatch: [],
  },
  'enzyme-ace': {
    label: "ACE and Angiotensin-Converting Enzymes",
    physiology: `Angiotensin-converting enzyme (ACE, kininase II) is a zinc-dependent dipeptidyl carboxypeptidase anchored to the luminal surface of vascular endothelium, particularly abundant in the pulmonary vasculature. It cleaves the C-terminal His-Leu dipeptide from angiotensin I to generate the potent vasoconstrictor angiotensin II, and simultaneously inactivates bradykinin—a vasodilatory and pro-inflammatory peptide. ACE is the key effector enzyme of the renin-angiotensin-aldosterone system (RAAS), and its activity is reduced in heart failure and augmented by sodium restriction or diuretic use. ACE2, a homolog, cleaves angiotensin II to vasodilatory angiotensin 1-7 and serves as the SARS-CoV-2 receptor.`,
    activation: `ACE inhibitors (captopril, lisinopril, enalaprilat) competitively bind the ACE zinc active site with a zinc-chelating moiety (thiol, carboxyl, or phosphonyl), preventing angiotensin II formation. The resulting dual effect—decreased angiotensin II (vasodilation, reduced aldosterone, reduced sympathetic activation) and increased bradykinin (additional vasodilation, enhanced natriuresis)—provides superior end-organ protection versus ARBs in some populations. Bradykinin accumulation is responsible for the 10-15% incidence of dry, non-productive cough that is the most common reason for ACE inhibitor discontinuation.`,
    disease: `ACE inhibitors are first-line for hypertension, HFrEF (reduce mortality, morbidity, and hospitalization), post-MI cardioprotection, diabetic nephropathy (reduce proteinuria and slow GFR decline), and in patients with CKD. The combination of ACE inhibitor and ARB (dual RAAS blockade) is generally avoided due to increased adverse effects without additional benefit. Sacubitril inhibits neprilysin (an ACE-homologous enzyme degrading natriuretic peptides) and is combined with valsartan (ARB); this combination cannot be co-administered with ACE inhibitors due to angioedema risk from additive bradykinin elevation.`,
    structure: `ACE is a type I transmembrane glycoprotein; its ectodomain contains two homologous catalytic domains (N- and C-domain) each harboring the canonical HEMGH zinc-binding motif. The C-domain is the primary site of angiotensin I conversion; the N-domain has distinct substrate selectivity. ACE inhibitor structure-activity relationship identifies three pharmacophore elements: a zinc-coordinating group (thiol > carboxylate > phosphonate for potency), a proline-mimicking scaffold for the penultimate residue, and C-terminal aromatic residue contacts with Phe512 and Tyr520.`,
    toxicology: `ACE inhibitor-induced angioedema is a bradykinin-mediated, mast cell-independent reaction that occurs in 0.1-0.5% of patients (more common in Black patients, up to 3.5%) and can affect the lips, tongue, pharynx, or larynx, causing life-threatening airway obstruction. Epinephrine and antihistamines have limited efficacy; icatibant (bradykinin B2 antagonist) and C1-esterase inhibitor concentrate are more effective. ACE inhibitors are absolutely contraindicated in pregnancy (second and third trimester: oligohydramnios, fetal renal failure, skull ossification defects). Hyperkalemia and acute kidney injury risk is amplified in patients with bilateral renal artery stenosis or volume depletion.`,
    familyMatch: ['ACE-inhibition','neprilysin-inhibition'],
    targetMatch: /ACE|angiotensin.converting enzyme|kininase/i,
    classMatch: [],
  },
  'enzyme-cox': {
    label: "Cyclooxygenase Enzymes (COX-1/COX-2)",
    physiology: `Cyclooxygenase (COX, prostaglandin H2 synthase) exists as two isoforms: COX-1, constitutively expressed in most tissues (gastric mucosa, platelets, kidney) where it generates cytoprotective prostaglandins and thromboxane A2; and COX-2, inducibly expressed in response to cytokines, growth factors, and tissue injury, producing prostaglandins that mediate pain, fever, and inflammation. Both isoforms convert arachidonic acid (released from membrane phospholipids by phospholipase A2) via dual cyclooxygenase and peroxidase activities to prostaglandin H2 (PGH2), the precursor to diverse eicosanoids. COX-3, a COX-1 splice variant expressed in the CNS, may partially explain acetaminophen analgesia and antipyresis.`,
    activation: `Non-selective COX inhibition (NSAIDs: ibuprofen, naproxen, indomethacin, ketorolac) provides analgesia, antipyresis, and anti-inflammatory effects by blocking prostaglandin synthesis at both isoforms. The therapeutic benefit (anti-inflammation) and toxicity (gastric ulceration from loss of PGE2/PGI2 mucosal protection) reflect simultaneous COX-1 inhibition. Aspirin uniquely acetylates a serine residue (Ser530 in COX-1, Ser516 in COX-2), irreversibly inactivating both isoforms; its antiplatelet effect persists for the platelet lifespan (7-10 days) because platelets cannot synthesize new COX. Selective COX-2 inhibitors (celecoxib) reduce GI toxicity but eliminate the antiplatelet effect of COX-1 inhibition.`,
    disease: `NSAIDs treat acute and chronic pain, osteoarthritis, rheumatoid arthritis, dysmenorrhea, gout attacks, pericarditis, fever, and ankylosing spondylitis. Low-dose aspirin (81 mg) irreversibly inhibits platelet COX-1 for antiplatelet therapy in cardiovascular disease prevention. Indomethacin closes patent ductus arteriosus in premature neonates (by blocking PGE2-mediated ductal relaxation). Ketorolac provides parenteral NSAID analgesia for acute pain. Celecoxib reduces colorectal polyp recurrence in FAP and provides arthritis analgesia with reduced GI bleeding risk.`,
    structure: `Both COX isoforms are homodimeric integral membrane glycoproteins in the ER and nuclear envelope. The active site consists of a long hydrophobic channel extending from the membrane into the protein; arachidonic acid enters in a bent conformation with C-1 carboxylate interacting with Arg120 and the omega-end lodged in a hydrophobic pocket capped by Tyr385 (radical transfer) and Ser530 (aspirin acetylation target). COX-2 has a larger active site (valine instead of isoleucine at position 523) that accommodates the bulkier sulfonamide/sulfone substituent of selective COX-2 inhibitors, providing the structural basis for selectivity.`,
    toxicology: `GI toxicity—from mucosal erosions to ulcer perforation and hemorrhage—is the principal class-wide adverse effect of NSAIDs, reduced 50% by co-prescription of proton pump inhibitors or by selective COX-2 inhibition. All NSAIDs (including COX-2 selective) carry FDA boxed warnings for cardiovascular events (MI, stroke); the rofecoxib (Vioxx) withdrawal in 2004 following the APPROVe trial established this risk. NSAIDs are contraindicated in pregnancy after 20 weeks gestation (premature closure of ductus arteriosus, fetal renal impairment). Renal prostaglandins maintain afferent arteriolar tone in volume-depleted or heart failure states; NSAID use causes acute kidney injury and sodium/water retention in these contexts.`,
    familyMatch: ['COX-inhibition','COX-2-selective-inhibition','COX-2-preferential','COX-3-inhibition','COX-2 (reversible at higher doses)'],
    targetMatch: /cyclooxygenase|COX.1|COX.2|prostaglandin H2 synthase/i,
    classMatch: [],
  },
  'enzyme-hmgcoa': {
    label: "HMG-CoA Reductase (Statins Target)",
    physiology: `HMG-CoA reductase (3-hydroxy-3-methylglutaryl coenzyme A reductase) catalyzes the rate-limiting, committed step in the mevalonate pathway: conversion of HMG-CoA to mevalonate. The mevalonate pathway generates cholesterol (principal precursor for bile acids, steroid hormones, and cell membranes), isoprenoid precursors for coenzyme Q10, dolichol, heme A, and prenylated proteins (Ras, Rho, Rab GTPases). Hepatic cholesterol synthesis is upregulated nocturnally and after meals; SREBP-2 transcription factor controls HMG-CoA reductase expression in response to intracellular cholesterol levels. Statins administered in the evening maximize inhibition during peak synthesis.`,
    activation: `Statin binding to HMG-CoA reductase competitively blocks the HMG moiety binding site, reducing hepatic cholesterol synthesis. The resulting intracellular cholesterol depletion upregulates LDL receptor expression via SREBP-2 activation, increasing receptor-mediated clearance of LDL-C from plasma by 30-55%. Pleiotropic effects—improved endothelial function, reduced inflammation (lower hsCRP), and anti-thrombotic effects—contribute to cardiovascular risk reduction beyond LDL lowering. High-intensity statins (atorvastatin 40-80 mg, rosuvastatin 20-40 mg) reduce LDL-C by 50% or more and are guideline-mandated after ACS and for primary prevention in high-risk patients.`,
    disease: `Statins are the cornerstone of dyslipidemia management and secondary cardiovascular disease prevention. They reduce LDL-C, modestly reduce triglycerides, and modestly increase HDL-C. ACC/AHA guidelines recommend high-intensity statin therapy for all patients post-ACS, with LDL-C above 70 mg/dL and atherosclerotic cardiovascular disease, and for primary prevention in patients with high 10-year ASCVD risk. Add-on therapies for LDL-C non-responders or statin-intolerant patients include ezetimibe (NPC1L1 inhibitor), PCSK9 inhibitors (evolocumab, alirocumab), and inclisiran (siRNA reducing PCSK9 synthesis).`,
    structure: `HMG-CoA reductase is a tetrameric enzyme with a catalytic domain projecting into the cytoplasm from the ER membrane. The HMG-CoA binding site is a deep cavity adjacent to the NADPH cofactor-binding domain; statins occupy the HMG-CoA binding site with their HMG-like moiety (dihydroxyheptanoic acid pharmacophore) and extend a rigid bicyclic or fluorophenyl-substituted pharmacophore that fills a hydrophobic pocket not used by the natural substrate. Differences in the hydrophobic extension differentiate statin potency, selectivity for hepatic uptake (via OATP1B1/1B3 transporters), and susceptibility to CYP3A4 metabolism.`,
    toxicology: `Statin-associated muscle symptoms (SAMS) range from myalgia (5-10% of patients) through myositis to the rare but potentially fatal rhabdomyolysis with myoglobinuria and acute kidney injury. Risk is amplified by high doses, co-prescription of CYP3A4 inhibitors (simvastatin/lovastatin), fibrates (especially gemfibrozil via OATP1B1 inhibition), cyclosporine, and hypothyroidism. Simvastatin 80 mg is no longer initiated in new patients due to rhabdomyolysis risk. Hepatotoxicity is rare (less than 1 per 10,000 patients); routine liver function monitoring beyond baseline is no longer recommended. Statin-induced new-onset type 2 diabetes occurs in approximately 0.1% per year of treatment and is outweighed by cardiovascular benefit in most patients.`,
    familyMatch: ['HMG-CoA-reductase-inhibition','statin'],
    targetMatch: /HMG.CoA|statin|mevalonate|cholesterol synthesis/i,
    classMatch: [],
  },
  'enzyme-pde': {
    label: "Phosphodiesterase Enzymes (PDE3, PDE4, PDE5)",
    physiology: `Phosphodiesterases (PDEs, 11 families) hydrolyze the 3-prime phosphate bond of cyclic AMP (cAMP) or cyclic GMP (cGMP), terminating second-messenger signaling. PDE3 (cardiac and vascular smooth muscle, platelets) hydrolyzes both cAMP and cGMP; elevated cAMP from PDE3 inhibition increases cardiac contractility and promotes vasodilation. PDE4 (inflammatory cells—neutrophils, eosinophils, T-cells, macrophages) is the dominant cAMP-hydrolyzing enzyme in immune cells; inhibition reduces cytokine production and inflammatory cell activation. PDE5 (corpus cavernosum, pulmonary vasculature, smooth muscle) hydrolyzes cGMP; inhibition potentiates NO-cGMP signaling to produce vasodilation.`,
    activation: `PDE3 inhibitors (milrinone, amrinone) increase cardiac cAMP, activating PKA to phosphorylate phospholamban (enhancing SR Ca2+ uptake) and L-type channels (increasing Ca2+ influx), producing positive inotropy and chronotropy with simultaneous vasodilation—the "inodilator" profile. PDE4 inhibitors (roflumilast) reduce inflammatory mediator production in COPD, modestly improving FEV1 and reducing exacerbations. PDE5 inhibitors (sildenafil, tadalafil, vardenafil, avanafil) potentiate penile smooth muscle relaxation from sexual stimulation-induced NO release (inhibiting PDE5-mediated cGMP breakdown), treating erectile dysfunction; the same mechanism in pulmonary vasculature treats pulmonary arterial hypertension.`,
    disease: `Milrinone is used for acute decompensated heart failure as a short-term inotropic and vasodilatory bridge; its pro-arrhythmic and mortality risks limit chronic oral use. Roflumilast prevents exacerbations in severe COPD (FEV1 less than 50% with chronic bronchitis phenotype). PDE5 inhibitors treat erectile dysfunction (sildenafil, tadalafil, vardenafil, avanafil), pulmonary arterial hypertension (sildenafil, tadalafil), and benign prostatic hyperplasia (tadalafil daily dosing). Dipyridamole (PDE3/5 inhibitor plus adenosine reuptake inhibitor) is used in combination with aspirin (Aggrenox) for secondary stroke prevention.`,
    structure: `PDE families share a conserved catalytic domain (~270 amino acids) with a metal-binding bimetallic center (Zn2+/Mg2+) and a glutamine switch mechanism that determines cAMP vs. cGMP selectivity. PDE5 selectivity for cGMP results from a "glutamine switch" Gln817 that positions cGMP optimally; PDE5 inhibitors mimic cGMP, binding the active site with a guanine mimic scaffold. The selectivity of sildenafil for PDE5 over PDE6 (retinal) is modest (~10-fold), accounting for the blue-tint visual disturbance at high doses. Tadalafil's longer half-life (17.5 vs. 4 hours for sildenafil) derives from additional hydrophobic contacts with a unique lid loop in the PDE5 binding site.`,
    toxicology: `PDE5 inhibitors are absolutely contraindicated with organic nitrates in any form; both pathways converge on cGMP elevation in vascular smooth muscle, and the combination causes life-threatening hypotension. Milrinone pro-arrhythmia (ventricular arrhythmias in structurally abnormal hearts) limits long-term use; it should not be used for non-surgical heart failure without clear hemodynamic indication. Roflumilast causes psychiatric adverse effects including anxiety, depression, insomnia, and suicidal ideation, requiring patient monitoring and precaution in patients with a history of psychiatric illness. PDE5 inhibitors cause headache (cephalic vasodilation), flushing, dyspepsia, and myalgia; sildenafil and vardenafil (but not tadalafil) inhibit PDE6 in retinal photoreceptors, causing reversible blue-tinted vision at higher doses.`,
    familyMatch: ['phosphodiesterase-3 (PDE3)','phosphodiesterase-4 (PDE4) in airway cells and leukocytes','phosphodiesterase (non-selective)','PDE5-inhibition'],
    targetMatch: /phosphodiesterase|PDE3|PDE4|PDE5/i,
    classMatch: [],
  },
  'enzyme-thymidylate': {
    label: "DNA Synthesis Enzymes (Thymidylate Synthase, Folate Pathway)",
    physiology: `Thymidylate synthase (TS) catalyzes the reductive methylation of deoxyuridine monophosphate (dUMP) to thymidine monophosphate (dTMP) using 5,10-methylenetetrahydrofolate (MTHF) as the methyl donor, providing the sole de novo source of thymidine for DNA synthesis. Dihydrofolate reductase (DHFR) regenerates tetrahydrofolate from dihydrofolate produced in the TS reaction, maintaining the reduced folate pool essential for one-carbon transfer reactions (thymidylate synthesis, purine synthesis, methionine/homocysteine cycle). Rapidly dividing cells—tumors, bacteria, parasites—are highly dependent on de novo thymidylate synthesis and are selectively vulnerable to antifolate drugs.`,
    activation: `Methotrexate (MTX) competitively inhibits DHFR with 1000-fold higher affinity than dihydrofolate, depleting reduced folate pools and secondarily inhibiting TS; it is used in oncology (high-dose) and rheumatology/immunology (low-dose). 5-Fluorouracil (5-FU) is converted intracellularly to FdUMP, which irreversibly inhibits TS by forming a ternary complex with the enzyme and MTHF; leucovorin (folinic acid, reduced folate) stabilizes this ternary complex, potentiating 5-FU cytotoxicity. Trimethoprim and pyrimethamine selectively inhibit bacterial and protozoal DHFR (100-1000-fold selectivity over mammalian DHFR), explaining their antimicrobial utility without severe myelotoxicity at therapeutic doses.`,
    disease: `Methotrexate is first-line for rheumatoid arthritis, psoriasis, psoriatic arthritis, and several malignancies (ALL, osteosarcoma, CNS lymphoma, gestational trophoblastic disease). 5-FU-based regimens (FOLFOX, FOLFIRI with leucovorin potentiation) are standards of care for colorectal, gastric, breast, and head-and-neck cancers. Capecitabine is an oral 5-FU prodrug activated in tumor tissue by thymidine phosphorylase. Trimethoprim-sulfamethoxazole (TMP-SMX) treats urinary tract infections, PCP prophylaxis/treatment, and community-acquired MRSA skin infections. Pyrimethamine-sulfadiazine treats toxoplasmosis.`,
    structure: `Human TS is a homodimer; each subunit binds dUMP in the nucleotide-binding domain and MTHF in the folate-binding domain, with the reactive Cys195 forming a covalent Michael adduct with C-6 of dUMP during catalysis. FdUMP (from 5-FU) forms an essentially irreversible ternary complex because the fluorine at C-5 prevents the beta-elimination step required for turnover. DHFR adopts an alpha-beta barrel fold with a hydrophobic active site cleft; MTX occupies the substrate binding site through conserved H-bond contacts with Glu30 and Leu22, with its pterin ring rotated 180 degrees relative to the folate substrate, preventing productive NADPH hydride transfer.`,
    toxicology: `MTX toxicity at high doses or in renal impairment produces mucositis, myelosuppression, and nephrotoxicity; leucovorin rescue after high-dose regimens bypasses DHFR inhibition to restore folate pools; MTX levels and renal function must be monitored. Low-dose MTX in rheumatology causes cumulative hepatic fibrosis requiring periodic liver biopsy or FibroScan monitoring with chronic use. 5-FU causes diarrhea, mucositis, myelosuppression, and palmar-plantar erythrodysesthesia (hand-foot syndrome with capecitabine); rare DPD enzyme deficiency (dihydropyrimidine dehydrogenase, the 5-FU catabolizing enzyme) causes severe life-threatening toxicity from standard doses and requires DPYD genotyping before therapy.`,
    familyMatch: ['thymidylate-synthase-inhibition','DHFR-inhibition','antifolate','folate-analog'],
    targetMatch: /thymidylate synthase|DHFR|dihydrofolate reductase|folate pathway|antifolate/i,
    classMatch: [],
  },
  'transporter-sert-dat-net': {
    label: "Monoamine Transporters (SERT, DAT, NET)",
    physiology: `The monoamine transporters—serotonin transporter (SERT/SLC6A4), dopamine transporter (DAT/SLC6A3), and norepinephrine transporter (NET/SLC6A2)—are sodium-dependent secondary active transporters of the SLC6 family that terminate monoaminergic neurotransmission by reuptaking released serotonin, dopamine, and norepinephrine from the synapse into the presynaptic terminal. SERT is expressed in serotonergic raphe neurons and platelets; DAT in dopaminergic neurons of the nigrostriatal, mesolimbic, and mesocortical tracts; NET in noradrenergic locus coeruleus neurons projecting to the cortex, hippocampus, and spinal cord. Cocaine inhibits all three transporters with similar potency, explaining its pronounced reinforcing and sympathomimetic properties.`,
    activation: `SERT inhibition by SSRIs (fluoxetine, sertraline, paroxetine, citalopram, escitalopram) elevates synaptic serotonin, producing antidepressant effects after 2-4 weeks of receptor desensitization; full clinical response requires persistent SERT occupancy and adaptive pre- and post-synaptic changes. SNRIs (venlafaxine, duloxetine, desvenlafaxine) inhibit both SERT and NET, providing antidepressant effects with additional noradrenergic contributions to pain modulation and attention. TCAs inhibit SERT and NET with variable selectivity, plus muscarinic, histaminergic, and alpha1-adrenergic receptor antagonism accounting for their side effect burden. ADHD stimulants (methylphenidate—DAT/NET; amphetamine—reversal of DAT/NET) increase prefrontal catecholamine availability.`,
    disease: `SERT inhibitors (SSRIs, SNRIs) treat major depressive disorder, generalized anxiety disorder, panic disorder, OCD, PTSD, social anxiety disorder, and bulimia nervosa. NET-selective agents (atomoxetine) treat ADHD without scheduling requirements. Mixed DAT/NET stimulants (methylphenidate, amphetamine) treat ADHD, narcolepsy, and—with extreme caution—treatment-resistant depression. Duloxetine's dual SERT/NET activity treats diabetic peripheral neuropathy, fibromyalgia, and stress urinary incontinence in addition to depression. The NET inhibitor reboxetine (not US-approved) treats depression in Europe.`,
    structure: `SLC6 transporters adopt the LeuT-like fold with 12 transmembrane helices; SERT, DAT, and NET share ~50% amino acid identity. The substrate binds the central S1 site between TM1, TM3, TM6, and TM8, coordinated by Na+ and Cl ions; the transport cycle alternates between outward-open, occluded, and inward-open conformations. SSRIs bind to the S1 site of SERT in the outward-open conformation, blocking serotonin access; the inhibitor is trapped by conformational closure. Tricyclic antidepressants bind the extended S2 allosteric site in the extracellular vestibule, allosterically inhibiting serotonin release from S1.`,
    toxicology: `SSRI discontinuation syndrome (paresthesias, "brain zaps," dizziness, flu-like symptoms, irritability) occurs most prominently with paroxetine (short half-life, strong SERT affinity), requiring slow taper over weeks. SSRI/SNRI plus serotonergic agent combinations risk serotonin syndrome. QT prolongation is a dose-dependent effect of citalopram/escitalopram via concurrent hERG block. Hyponatremia (SIADH) is a class effect of SSRIs, most common in elderly women and within the first month of therapy. Stimulant abuse, cardiovascular toxicity (tachycardia, hypertension, MI), and psychosis risk with dopaminergic excess highlight the narrow therapeutic window in ADHD treatment.`,
    familyMatch: ['SERT-inhibition','DAT-NET-inhibition','monoamine-reuptake-inhibition','NET-inhibition'],
    targetMatch: /SERT|DAT|NET|serotonin transporter|dopamine transporter|norepinephrine transporter|monoamine reuptake/i,
    classMatch: ['transporter-inhibitors'],
  },
  'transporter-sglt2': {
    label: "SGLT2 Transporters (Sodium-Glucose Cotransporters)",
    physiology: `Sodium-glucose cotransporter 2 (SGLT2, SLC5A2) is expressed almost exclusively in the S1/S2 segments of the proximal renal tubule, where it mediates approximately 90% of filtered glucose reabsorption driven by the basolateral Na+/K+-ATPase electrochemical gradient. SGLT1 (expressed in intestine and S3 segment) accounts for the remaining ~10% of renal glucose reabsorption. Under normoglycemic conditions, nearly all filtered glucose is reclaimed by SGLT2 and SGLT1, with a renal glucose threshold of approximately 180-200 mg/dL; above this threshold, glycosuria occurs. In type 2 diabetes, SGLT2 expression is upregulated, raising the renal glucose threshold and worsening hyperglycemia.`,
    activation: `SGLT2 inhibitors (empagliflozin, dapagliflozin, canagliflozin, ertugliflozin) competitively block SGLT2, reducing renal glucose reabsorption by 30-50% and causing glucosuria of 60-90 g/day, lowering plasma glucose in an insulin-independent manner. The resulting caloric loss (240-360 kcal/day) promotes modest weight loss (2-4 kg). Osmotic diuresis and natriuresis reduce blood pressure and preload. Tubuloglomerular feedback and reduced intraglomerular pressure (via increased sodium delivery to the macula densa and efferent arteriole vasoconstriction) are proposed mechanisms for observed renoprotection independent of glucose lowering.`,
    disease: `SGLT2 inhibitors are FDA-approved for type 2 diabetes, HFrEF (empagliflozin, dapagliflozin—reduce hospitalizations and cardiovascular death), HFpEF (dapagliflozin—reduces HF hospitalizations), and CKD with albuminuria (empagliflozin, dapagliflozin—slow GFR decline). Dapagliflozin has a broad cardiovascular-renal indication spanning HF across ejection fraction range. SGLT2 inhibitors are uniquely able to provide glycemic benefit, heart failure protection, and renoprotection simultaneously, making them important add-on therapy for patients with T2DM and established CVD, HF, or CKD.`,
    structure: `SGLT2 is a member of the SLC5A family with 14 transmembrane helices. The sugar binding site is formed by residues in TM2, TM3, TM10, and TM11; glucose coordinates Na+ through hydroxyls at C-2, C-3, and C-4. SGLT2 inhibitors are C-glucoside analogs (empagliflozin, dapagliflozin) or O-glucoside precursors; the C-glycosidic bond is resistant to glucosidase cleavage, providing metabolic stability. Selectivity for SGLT2 over SGLT1 (more than 1000-fold for empagliflozin, dapagliflozin) is achieved by exploiting the larger aglycone binding pocket of SGLT2.`,
    toxicology: `Genitourinary infections (vulvovaginal candidiasis in women, balanitis in men) occur in 4-8% of patients due to glucosuria creating a favorable environment for fungal growth; topical antifungals are effective. Rare but severe euglycemic diabetic ketoacidosis (DKA) occurs with normal or near-normal blood glucose (masking the diagnosis) from relative insulinopenia and increased glucagon/ketogenesis; risk is highest with insulin dose reduction, fasting, surgery, or alcohol use. SGLT2 inhibitors should be held 3 days before elective surgery. Canagliflozin carries a boxed warning for lower-extremity amputation (mechanism unclear, possibly hemodynamic/volume effects on perfusion in high-risk patients). Fournier gangrene (necrotizing fasciitis of the genitalia) is a rare but life-threatening class effect.`,
    familyMatch: ['SGLT2-inhibition','sodium-glucose cotransporter'],
    targetMatch: /SGLT2|SGLT1|sodium.glucose cotransporter/i,
    classMatch: [],
  },
  'transporter-pgp': {
    label: "P-Glycoprotein and Efflux Transporters (P-gp, OATP)",
    physiology: `P-glycoprotein (P-gp, MDR1, ABCB1) is an ATP-binding cassette (ABC) efflux transporter highly expressed at the intestinal epithelium (limiting oral absorption), blood-brain barrier (limiting CNS penetration), hepatocyte canalicular membrane (biliary excretion), renal proximal tubule, and tumor cell membranes. It actively pumps structurally diverse lipophilic cationic substrates back into the intestinal lumen or out of cells, functioning as a broad-spectrum detoxification mechanism. OATP1B1 and OATP1B3 (SLC21A6/SLC21A8) are hepatic uptake transporters that facilitate extraction of statins, immunosuppressants, and numerous other drugs from portal blood into hepatocytes for metabolism and biliary excretion.`,
    activation: `P-gp inhibition by cyclosporine, amiodarone, verapamil, dronedarone, clarithromycin, or itraconazole increases bioavailability and decreases clearance of P-gp substrates (digoxin, dabigatran, rivaroxaban, apixaban, fexofenadine, loperamide). Digoxin is the canonical P-gp substrate; amiodarone and verapamil co-administration increase digoxin levels 40-70% and 50-75%, respectively, necessitating digoxin dose reduction. OATP1B1 inhibition by cyclosporine, gemfibrozil, or rifampin increases plasma AUC of statin substrates (simvastatin, atorvastatin, rosuvastatin) 2-10-fold, raising myopathy risk. OATP inhibition also elevates plasma methotrexate levels, increasing toxicity.`,
    disease: `P-gp-mediated multidrug resistance is a major cause of chemotherapy failure in cancer; P-gp overexpression confers resistance to taxanes, anthracyclines, vinca alkaloids, and topoisomerase inhibitors. The P-gp expression phenotype of the tumor guides selection of MDR-overcoming chemotherapy regimens. P-gp at the blood-brain barrier limits CNS penetration of numerous CNS-targeted drugs and also protects the brain from toxins. BCRP (ABCG2) is another efflux transporter relevant to statin, methotrexate, and topotecan transport; gefitinib and rosuvastatin are BCRP substrates.`,
    structure: `P-gp consists of two homologous halves, each comprising a transmembrane domain (TMD1/2, 6 TM helices each) and a nucleotide-binding domain (NBD1/2). Two ATP molecules bind at the NBD dimer interface; ATP hydrolysis drives conformational cycling between inward-facing (substrate-binding) and outward-facing (substrate-releasing) states. The substrate-binding cavity within the TMD is large and amphipathic, accommodating structurally diverse lipophilic drugs; multiple drug-binding sites (R-site for rhodamine/Hoechst, H-site for Hoechst and colchicine) exist within the same central cavity, explaining polyspecificity.`,
    toxicology: `Clinically significant P-gp drug interactions are responsible for approximately 30% of pharmacokinetic drug interactions in clinical practice. Rifampin P-gp induction reduces plasma levels of antiretrovirals, dabigatran, and immunosuppressants, causing subtherapeutic drug exposure and treatment failure. St. John Wort induces both P-gp and CYP3A4, reducing levels of cyclosporine, antiretrovirals, warfarin, and oral contraceptives—a clinically important herbal interaction requiring patient counseling. Quinidine inhibits both P-gp and CYP2D6; its use as a P-gp modulator to enhance CNS drug delivery is investigational.`,
    familyMatch: ['P-gp-substrate','OATP-substrate','efflux-transporter','ABC-transporter'],
    targetMatch: /P.glycoprotein|P.gp|MDR1|ABCB1|OATP|efflux transporter/i,
    classMatch: [],
  },
  'structural-tubulin': {
    label: "Tubulin / Microtubule Targets",
    physiology: `Microtubules are dynamic polymers of alpha/beta-tubulin heterodimers organized into hollow cylindrical protofilaments that perform essential cellular functions: mitotic spindle formation and chromosome segregation, intracellular vesicular transport (axonal and dendritic), cell shape maintenance, and ciliary/flagellar motility. The mitotic spindle is composed of kinetochore microtubules (chromosome capture), interpolar microtubules (antiparallel overlapping for spindle elongation), and astral microtubules (cortical anchoring). Dynamic instability—rapid alternation between polymerization (GTP-tubulin addition) and catastrophic depolymerization—is regulated by microtubule-associated proteins (MAPs) and is essential for chromosome alignment and segregation fidelity.`,
    activation: `Tubulin-binding drugs act through two principal mechanisms: stabilization of microtubule polymers (taxanes—paclitaxel, docetaxel) or destabilization/depolymerization (vinca alkaloids—vincristine, vinblastine, vinorelbine). Taxanes bind the beta-tubulin taxane site within the microtubule lumen, stabilizing the polymer in the GDP-bound state and preventing depolymerization; this arrests cells in mitosis (spindle assembly checkpoint activation). Vinca alkaloids bind the vinca domain at the interdimer interface between beta and alpha-tubulin of adjacent protofilaments, preventing GTP-tubulin addition and inducing spiral protofilament formation; cells arrest in metaphase with disrupted spindles.`,
    disease: `Taxanes are first-line chemotherapy for breast cancer (paclitaxel, docetaxel), ovarian cancer, NSCLC, and prostate cancer (docetaxel, cabazitaxel). Vinca alkaloids are used in hematologic malignancies (vincristine in CHOP for lymphoma, ALL; vinblastine in ABVD for Hodgkin lymphoma) and solid tumors (vinorelbine in NSCLC, breast). Colchicine (tubulin depolymerizer) treats acute gout (inhibiting neutrophil migration and NLRP3 inflammasome activation) and pericarditis, and carries a cardiovascular mortality reduction indication. Griseofulvin disrupts fungal tubulin for dermatophytosis treatment.`,
    structure: `The taxane binding site is located in the beta-tubulin luminal surface within the polymer, between helices H6, H7, the B7/H9 loop, and the M loop; paclitaxel stabilizes the M loop in a conformation that promotes tubulin lateral contacts between protofilaments. The vinca domain is at the exchangeable GTP site of beta-tubulin at the plus-end of the microtubule; vinca alkaloids form wedges that curve protofilaments outward, promoting spiral/ring tubulin oligomers incompatible with cylindrical microtubule structure. Resistance arises through beta-tubulin mutations in the drug-binding sites, overexpression of the betaIII-tubulin isotype (less responsive to taxanes), and P-glycoprotein-mediated drug efflux.`,
    toxicology: `Neurotoxicity is the dose-limiting toxicity of both vincristine (sensorimotor peripheral neuropathy, ileus, SIADH—most neurotoxic vinca) and paclitaxel (painful symmetric distal sensorimotor neuropathy); toxicity is cumulative and may be irreversible. Paclitaxel formulated in Cremophor EL (polyoxyethylated castor oil) causes severe hypersensitivity reactions requiring premedication with corticosteroids and antihistamines; albumin-bound nab-paclitaxel eliminates Cremophor but retains neuropathy risk. Myelosuppression (neutropenia) is the dose-limiting toxicity of docetaxel and vinorelbine. Taxane- and vinca-induced neutropenia nadirs occur 10-14 days post-treatment; G-CSF (filgrastim/pegfilgrastim) prophylaxis is recommended for high-risk regimens. Colchicine toxicity in overdose is catastrophic—GI hemorrhage followed by multi-organ failure; there is no antidote.`,
    familyMatch: ['tubulin (microtubule polymerization)','taxane','vinca-alkaloid'],
    targetMatch: /tubulin|microtubule|taxane|vinca|colchicine binding/i,
    classMatch: [],
  },
  'structural-dna': {
    label: "DNA Structural Targets (Topoisomerase, DNA Alkylation)",
    physiology: `DNA topoisomerases resolve topological stress during DNA replication and transcription. Topoisomerase I (Top1) creates transient single-strand nicks to relieve torsional stress; topoisomerase II (Top2alpha and Top2beta) creates transient double-strand breaks to allow passage of one DNA duplex through another. The topoisomerase-DNA complex ("cleavable complex") is a normal catalytic intermediate; stabilization of this complex by drugs converts it into a permanent DNA lesion triggering apoptosis. Alkylating agents form covalent adducts with DNA nucleophilic sites (primarily N7 of guanine), causing intrastrand or interstrand cross-links that stall replication forks and trigger the DNA damage response.`,
    activation: `Topoisomerase I poisons (camptothecins: topotecan, irinotecan) stabilize the Top1-DNA cleavable complex; when the replication fork collides with this complex, irreversible double-strand breaks occur selectively in S-phase cells. Topoisomerase II poisons (anthracyclines: doxorubicin, epirubicin; epipodophyllotoxins: etoposide) stabilize Top2alpha-DNA complexes, producing cytotoxicity in both dividing and non-dividing cells. Alkylating agents (nitrogen mustards: cyclophosphamide, ifosfamide; platinum compounds: cisplatin, carboplatin, oxaliplatin; nitrosoureas: carmustine; temozolomide; busulfan) form mono-adducts and interstrand/intrastrand crosslinks that prevent strand separation for replication.`,
    disease: `Topotecan treats ovarian and small-cell lung cancer; irinotecan is a prodrug converted to SN-38 by intestinal UGT1A1 (UGT1A1*28 polymorphism predicts severe toxicity) and treats colorectal cancer as FOLFIRI and FOLFIRINOX. Etoposide treats SCLC, germ cell tumors, and lymphomas. Anthracyclines (doxorubicin in CHOP, AC breast regimens; daunorubicin in AML) are among the most important antitumor agents. Cyclophosphamide alkylates and is used in breast cancer, lymphoma, leukemia, nephrotic syndrome, and autoimmune diseases. Cisplatin/carboplatin/oxaliplatin are backbones of regimens for testicular, ovarian, lung, colorectal, bladder, and head-and-neck cancers.`,
    structure: `The Top1 catalytic mechanism involves nucleophilic attack by Tyr723 on the DNA phosphodiester backbone; camptothecins intercalate into the Top1-DNA interface, wedging between DNA base pairs to prevent religation. The anthracycline chromophore intercalates between DNA base pairs; the amino sugar (daunosamine) extends into the minor groove making contacts with flanking nucleotides, explaining sequence selectivity. Platinum compounds undergo aquation (replacement of chloride ligands with water at the low intracellular chloride concentration), producing reactive diaqua species that form 1,2-d(GpG) intrastrand crosslinks (more than 65% of adducts) bending DNA ~40 degrees and preventing helicase unwinding.`,
    toxicology: `Anthracycline cumulative cardiotoxicity (dilated cardiomyopathy) is dose-dependent with a threshold of ~450 mg/m2 for doxorubicin; dexrazoxane chelates iron and prevents reactive oxygen species formation from the anthracycline-iron complex, providing cardioprotection. Irinotecan causes early (cholinergic-mediated, atropine-responsive) and late (UGT1A1-polymorphism-dependent, severe secretory) diarrhea requiring proactive management. Cisplatin causes cumulative nephrotoxicity (proximal tubular necrosis), ototoxicity (cisplatin more than carboplatin), and peripheral neuropathy; aggressive IV hydration and amifostine (cytoprotector) reduce nephrotoxicity. Cyclophosphamide produces acrolein-mediated hemorrhagic cystitis (prophylaxis: mesna; hydration); SIADH from high doses; and secondary malignancies (AML, transitional cell carcinoma).`,
    familyMatch: ['topoisomerase-inhibition','DNA-alkylation','DNA-crosslinking','anthracycline','platinum'],
    targetMatch: /topoisomerase|DNA alkylat|DNA crosslink|anthracycline|platinum.DNA|camptothecin/i,
    classMatch: [],
  },
};

export async function getStaticPaths() {
  const slugs = [
    'gpcr-adrenergic','gpcr-cholinergic','gpcr-opioid','gpcr-histamine',
    'gpcr-angiotensin','gpcr-glp1','gpcr-dopamine','gpcr-serotonin',
    'ligand-gated-channels','voltage-gated-sodium','voltage-gated-calcium','voltage-gated-potassium',
    'nuclear-receptors','receptor-tyrosine-kinases','serine-threonine-kinases',
    'enzyme-ace','enzyme-cox','enzyme-hmgcoa','enzyme-pde','enzyme-thymidylate',
    'transporter-sert-dat-net','transporter-sglt2','transporter-pgp',
    'structural-tubulin','structural-dna',
  ];
  return slugs.map((slug) => ({
    params: { target: slug },
    props: { slug },
  }));
}

interface Props { slug: string; }
const { slug } = Astro.props as Props;
const info = targetMap[slug];

type Drug = {
  id: string;
  generic_name: string;
  drug_class?: string;
  mechanism_summary?: string;
  indications?: string[];
  ismp_high_alert?: boolean;
  schema_memberships?: { mechanism_family?: string[]; therapeutic_class?: string[] };
  mechanism_targets?: string[];
  therapeutic_classes?: string[];
};

const allDrugs = drugsData as Drug[];

const drugs = allDrugs.filter((d) => {
  const families: string[] = d.schema_memberships?.mechanism_family ?? [];
  const targets: string[] = d.mechanism_targets ?? [];
  const classes: string[] = d.therapeutic_classes ?? [];
  return (
    families.some((f) => info.familyMatch.some((fm) =>
      f.toLowerCase().includes(fm.toLowerCase()) || fm.toLowerCase().includes(f.toLowerCase())
    )) ||
    targets.some((t) => info.targetMatch.test(t)) ||
    (info.classMatch.length > 0 && classes.some((c) => info.classMatch.includes(c)))
  );
});

const base = import.meta.env.BASE_URL;
---
<SchemaLayout
  title={`${info.label} — Mechanism-First`}
  schema="mechanism-first"
  description={`Pharmacology of ${info.label}: physiology, drug mechanisms, clinical applications, and nursing considerations.`}
>
  <nav class="breadcrumbs text-sm mb-6">
    <ul>
      <li><a href={`${base}schemas/04-mechanism-first/`} class="link link-hover">Mechanism-First</a></li>
      <li>{info.label}</li>
    </ul>
  </nav>

  <h1 class="text-3xl font-serif font-bold mb-6">{info.label}</h1>

  <div class="prose max-w-none mb-8 space-y-4">
    <p><strong>Structure and Normal Physiology.</strong> {info.physiology}</p>
    <p><strong>Pharmacological Effects of Activation vs. Inhibition.</strong> {info.activation}</p>
    <p><strong>Disease Rationale for Targeting.</strong> {info.disease}</p>
    <p><strong>Structural Features Drugs Exploit.</strong> {info.structure}</p>
    <p><strong>Toxicology of Over-Activation or Over-Inhibition.</strong> {info.toxicology}</p>
  </div>

  {drugs.length > 0 ? (
    <div>
      <h2 class="text-xl font-semibold mb-3">Drugs Acting at This Target ({drugs.length})</h2>
      <div class="overflow-x-auto">
        <table class="table table-zebra w-full">
          <thead>
            <tr>
              <th>Drug</th>
              <th>Class</th>
              <th>Mechanism Summary</th>
              <th>Key Indication</th>
            </tr>
          </thead>
          <tbody>
            {drugs.map((d) => (
              <tr>
                <td>
                  <a href={`${base}drugs/${d.id}/`} class="link link-primary font-medium">
                    {d.generic_name}
                  </a>
                  {d.ismp_high_alert && (
                    <span class="badge badge-error badge-sm ml-1">HIGH ALERT</span>
                  )}
                </td>
                <td class="text-sm">{d.drug_class ?? '—'}</td>
                <td class="text-sm">
                  {d.mechanism_summary
                    ? d.mechanism_summary.slice(0, 120) + (d.mechanism_summary.length > 120 ? '…' : '')
                    : '—'}
                </td>
                <td class="text-sm">{d.indications?.[0] ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  ) : (
    <div class="alert alert-info">
      <span>
        No drugs in the current database matched this target family. Expand drug entries with
        matching <code>mechanism_targets</code> or <code>schema_memberships.mechanism_family</code> values.
      </span>
    </div>
  )}
</SchemaLayout>
