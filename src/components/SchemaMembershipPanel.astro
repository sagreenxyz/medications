---
export interface Props {
  memberships: Record<string, string[]>;
}
const { memberships } = Astro.props;
---
<div class="card bg-base-200 mt-8">
  <div class="card-body">
    <h2 class="card-title text-lg">Schema Memberships</h2>
    <p class="text-sm text-base-content/70">This drug appears in the following schema pages:</p>
    <div class="flex flex-wrap gap-2 mt-2">
      {Object.entries(memberships).map(([schema, pages]) =>
        pages.map(page => (
          <span class="badge badge-outline">{schema}: {page}</span>
        ))
      )}
    </div>
  </div>
</div>
